// Stralis Ticketing System — data model
// See: Stralis_Ticketing_TRD.md §3, Stralis_Build_Spec.md §B-3

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  // "native" = the dev machine; "debian-openssl-3.0.x" is for the Docker
  // image (node:*-bookworm-slim, AWS/Azure container option); "rhel-openssl-3.0.x"
  // is for Vercel's serverless functions (Amazon Linux 2023 runtime). All
  // three are generated so `prisma generate` at build time works everywhere
  // this app might run. If you switch the Docker base image to Alpine,
  // change debian-openssl-3.0.x to "linux-musl-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantType {
  INTERNAL
  CLIENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum Role {
  CLIENT
  AGENT
  ADMIN
  SUPER_ADMIN
}

// PENDING: self-registered, awaiting a tenant admin's approval (see the
// email flow design doc). ACTIVE: can log in. REJECTED/SUSPENDED: cannot —
// distinguished so admins can tell "we said no" from "was deactivated later".
// INVITED: an admin created this account directly (Team > Invite) — the
// person has an email link to accept but hasn't set their own password yet,
// so they can't log in normally until they do (see actions/admin.ts's
// inviteUser() and actions/auth.ts's acceptInvite()).
// UNVERIFIED: self-registered but hasn't confirmed the email is theirs yet
// (see registerClient()/verifyRegistrationOtp() in actions/auth.ts) — never
// shown in the admin approval queue, since there's no point asking an admin
// to review a registration nobody's confirmed is a real address yet.
enum UserStatus {
  UNVERIFIED
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  INVITED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SenderRole {
  CLIENT
  AGENT
  ADMIN
  SYSTEM
  BOT
  // A person added to one ticket via a guest invite link (see TicketGuest) —
  // never has a User row, so Message.senderId stays null for these and
  // Message.guestId identifies who wrote it instead.
  GUEST
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  type         TenantType   @default(CLIENT)
  status       TenantStatus @default(ACTIVE)
  customDomain String?      @unique
  createdAt    DateTime     @default(now())

  branding      TenantBranding?
  chatbotConfig ChatbotConfig?
  users         User[]
  tickets       Ticket[]
  categories    Category[]
  kbArticles    KbArticle[]
  chatConversations ChatConversation[]
  auditLogs     AuditLog[]
  notifications Notification[]
  ticketGuests  TicketGuest[]
  surveyResponses SurveyResponse[]
  companies     Company[]

  @@map("tenants")
}

model TenantBranding {
  tenantId      String  @id
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl       String?
  faviconUrl    String?
  primaryColor  String  @default("#FF6A00")
  accentColor   String  @default("#000000")
  productName   String  @default("Support")
  // The tenant's one dedicated inbound support address (e.g.
  // support@acme.com) — inbound webhook matches on this to route an email
  // to the right tenant before any ticket/user exists. Unique so two
  // tenants can never claim the same inbound mailbox.
  supportEmail   String? @unique
  // Provider-side inbound route/webhook id (Resend inbound route), stored
  // for reference/cleanup — not read by the app at request time.
  inboundRouteId String?
  emailFromName String?
  emailDomain   String?
  customCss     String?

  @@map("tenant_branding")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passwordHash String // bcrypt. TODO(decision): swap to Supabase Auth (or another provider) before production.
  name         String
  email        String
  role         Role     @default(CLIENT)
  // Legacy free-text company field — retained for backwards compatibility
  // during the Team & Roles v2 backfill. New writes should populate
  // companyId (below) via the auto-match-by-email-domain flow in
  // registerClient/inviteUser; this string will be dropped once every
  // active row has been backfilled to a Company reference.
  company      String?
  companyId    String?
  companyRef   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  status       UserStatus @default(PENDING)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  // Set whenever the password changes. Any session JWT issued (iat) before
  // this instant is rejected in getSessionUser(), so a password change
  // invalidates all *other* existing sessions (the changing session is
  // re-issued a fresh cookie). See src/lib/auth.ts + src/actions/profile.ts.
  passwordChangedAt DateTime?

  // Team & Roles v2 audit trail (spec §2). *ById fields are deliberately
  // not FK'd back to User to keep the audit stub around even if the acting
  // admin later gets deleted — same reasoning as AuditLog.actorId. Every
  // action (approve/reject/invite/deactivate) writes an AuditLog row too;
  // these here are the "most recent of each event" summary for the row.
  lastActiveAt DateTime?
  invitedAt    DateTime?
  invitedById  String?
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?

  tickets       Ticket[]      @relation("ClientTickets")
  assigned      Ticket[]      @relation("AssignedAgent")
  messages      Message[]
  uploadedAttachments Attachment[]
  chatConversations ChatConversation[]
  auditLogs     AuditLog[]
  notifications Notification[]
  invitedGuests TicketGuest[]
  loginOtps     LoginOtp[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, companyId])
  @@map("users")
}

// Companies scope users by organizational membership. `domain` is used to
// auto-match new registrants (e.g. someone signing up with @northwind.io
// gets linked to the Northwind Retail company automatically instead of an
// admin doing it by hand — see registerClient/inviteUser). `country` is
// ISO 3166-1 alpha-2 (matches the same convention as Ticket.clientCountry
// so it can feed the analytics region map). @@unique([tenantId, name])
// prevents accidental dupes; there is *no* unique on domain because two
// tenants can validly claim to be the "Acme Corp" they both know about.
model Company {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  country   String?
  domain    String?
  createdAt DateTime @default(now())

  users User[]

  @@unique([tenantId, name])
  @@index([tenantId, domain])
  @@map("companies")
}

model Category {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true)
  tickets  Ticket[]

  @@unique([tenantId, name])
  @@map("categories")
}

// ---------------------------------------------------------------------------
// Tickets
// ---------------------------------------------------------------------------

model Ticket {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference    String
  // Short numeric id (e.g. "12707664") embedded in every notification
  // subject as "[#12707664]" — kept separate from `reference` because email
  // clients mangle subject lines, so inbound reply-matching needs the
  // simplest possible token to regex out. Globally unique (not per-tenant)
  // since the inbound webhook doesn't know the tenant until it's resolved
  // the ticket this number belongs to.
  ticketNumber String       @unique
  // Message-ID of the last outbound notification for this ticket, so a
  // client's email reply can thread back via In-Reply-To/References as a
  // fallback when the subject tag itself got stripped.
  emailMessageId String?
  title        String
  description  String
  status       TicketStatus @default(OPEN)
  priority     Priority     @default(MEDIUM)
  categoryId   String?
  category     Category?    @relation(fields: [categoryId], references: [id])
  clientId     String
  client       User         @relation("ClientTickets", fields: [clientId], references: [id])
  assignedToId String?
  assignedTo   User?        @relation("AssignedAgent", fields: [assignedToId], references: [id])
  source       String       @default("portal") // portal | chatbot | email
  firstReplyAt DateTime?
  resolvedAt   DateTime?
  // Reopen tracking (analytics: reopen-rate KPI). reopenedAt is the most
  // recent reopen timestamp; reopenCount is a running total across the
  // ticket's lifetime, incremented whenever it transitions OUT of
  // RESOLVED/CLOSED back into an active status (see reopenTicket() and
  // updateTicket() in actions/tickets.ts).
  reopenedAt   DateTime?
  reopenCount  Int          @default(0)
  // Captured at creation time from the requester's HTTP request (portal/
  // chatbot only — email-sourced tickets have no live request, so both stay
  // null). clientCountry is an ISO 3166-1 alpha-2 code resolved from
  // clientIp via geoip-lite (offline lookup, no external API call) —
  // powers the analytics "clients by region" map/table. Never backfilled
  // for tickets created before this field existed.
  clientIp      String?
  clientCountry String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  messages    Message[]
  attachments Attachment[]
  auditLogs   AuditLog[]
  chatConversations ChatConversation[]
  notifications Notification[]
  guests      TicketGuest[]
  surveyResponse SurveyResponse?

  @@unique([tenantId, reference])
  @@index([tenantId, status, priority])
  @@map("tickets")
}

// One CSAT rating per ticket — see actions/csat.ts's submitCsatRating()
// (an unauthenticated, token-scoped action reached via the emailed
// "rate this ticket" link, actions/tickets.ts's updateTicket()). Resubmitting
// the same link overwrites the existing row rather than erroring, so
// ticketId is unique instead of having its own separate id-based history.
model SurveyResponse {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("survey_responses")
}

model Message {
  id         String      @id @default(cuid())
  tenantId   String
  ticketId   String
  ticket     Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String?
  sender     User?       @relation(fields: [senderId], references: [id])
  // Set instead of senderId when a GUEST (see TicketGuest) wrote this message
  // — a guest never gets a User row, so this is how the message is attributed.
  guestId    String?
  guest      TicketGuest? @relation(fields: [guestId], references: [id])
  senderRole SenderRole
  body       String
  isInternal Boolean     @default(false)
  createdAt  DateTime    @default(now())

  attachments Attachment[]

  @@index([tenantId, ticketId])
  @@map("messages")
}

model Attachment {
  id         String   @id @default(cuid())
  tenantId   String
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Null until the composer's "Send" actually posts the message the file was
  // staged for (see actions/attachments.ts uploadTicketAttachment /
  // actions/tickets.ts's postAgentReply|postClientReply) — an uploaded-but-
  // never-sent file just stays unlinked, still visible in Files & Links.
  messageId  String?
  message    Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?  @relation(fields: [uploadedById], references: [id])
  // Storage object PATH, not a public URL — this bucket is private (ticket
  // attachments aren't "public by nature" like branding logos/avatars are).
  // Resolved to a short-lived signed URL on read; see lib/storage.ts.
  fileUrl    String
  fileName   String
  mimeType   String
  sizeBytes  Int
  uploadedAt DateTime @default(now())

  @@index([tenantId, ticketId])
  @@index([messageId])
  @@map("attachments")
}

// A person added to exactly one ticket via an emailed magic link — no
// account, no password, no session cookie. invitedById is the staff/client
// User who added them; the guest's own identity is just email (+ optional
// name) carried on this row and denormalized onto any Message they send
// (Message.guestId). tokenHash is sha256 of the raw token that goes in the
// email; only the hash is ever stored (same pattern as password-reset,
// except this one needs server-side state since it's revocable/long-lived
// rather than a short single-use JWT).
model TicketGuest {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  tokenHash   String    @unique
  invitedById String?
  invitedBy   User?     @relation(fields: [invitedById], references: [id])
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  messages Message[]

  @@index([tenantId, ticketId])
  @@map("ticket_guests")
}

// Server-side state for the one-time email code verified at invite
// acceptance (first login only — see actions/auth.ts's acceptInvite() /
// verifyLoginOtp()). Deliberately NOT a JWT like session/reset tokens,
// since a code needs to be matched against a value already emailed out
// (can't just re-derive/re-verify a signature the way a stateless token
// works) and single-use tracked independent of any password change.
model LoginOtp {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("login_otps")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String // STATUS_CHANGE | PRIORITY_CHANGE | ASSIGN | REPLY | REOPEN | ...
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  @@index([tenantId, ticketId])
  @@map("audit_logs")
}

// In-app notification bell (nav-bar.tsx). Deliberately separate from the
// email system (lib/email/) — a notification is a personal, per-user inbox
// item ("you were assigned a ticket"), not a tenant-wide log like AuditLog
// or an outbound message like the email templates. Written via createMany()
// everywhere (see lib/notifications.ts), never .create() — Prisma's
// .create() always does an implicit RETURNING checked against SELECT
// policies, and the actor creating a notification (e.g. a client replying)
// is essentially never the same user as the notification's recipient (the
// assigned agent), so that RETURNING check would fail under RLS the same
// way the audit_logs one originally did (see rls_policies.sql). createMany()
// has no RETURNING, sidestepping the problem entirely — we don't need the
// created row back anyway.
model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // TICKET_REPLY | STATUS_CHANGE | ASSIGNED | REGISTRATION_PENDING | REGISTRATION_APPROVED | REGISTRATION_REJECTED
  title     String
  body      String?
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, userId, isRead, createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// AI / Knowledge base / Chatbot
// ---------------------------------------------------------------------------

model KbArticle {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  body        String
  isPublished Boolean   @default(false)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  chunks      KbChunk[]

  @@index([tenantId])
  @@map("kb_articles")
}

model KbChunk {
  id        String    @id @default(cuid())
  tenantId  String
  articleId String
  article   KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  // TODO(decision): swap to pgvector `vector(1536)` once the AI/M5 milestone
  // is built and a Postgres with the pgvector extension is provisioned.
  // Storing as a plain float array keeps local dev unblocked without it.
  embedding Json?

  @@index([tenantId])
  @@map("kb_chunks")
}

model ChatbotConfig {
  tenantId      String  @id
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled     Boolean @default(true)
  persona       String  @default("a friendly support assistant")
  systemPrompt  String?
  deflectFirst  Boolean @default(true)
  escalateAfter Int     @default(3)
  allowedTopics String?

  @@map("chatbot_configs")
}

model ChatConversation {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  status    String        @default("active") // active | escalated | closed
  ticketId  String?
  ticket    Ticket?       @relation(fields: [ticketId], references: [id])
  createdAt DateTime      @default(now())
  messages  ChatMessage[]

  @@index([tenantId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           SenderRole
  body           String
  citations      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}
