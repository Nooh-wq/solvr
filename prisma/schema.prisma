// Stralis Ticketing System — data model
// See: Stralis_Ticketing_TRD.md §3, Stralis_Build_Spec.md §B-3

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" = the dev machine; "debian-openssl-3.0.x" is for the Docker
  // image (node:*-bookworm-slim, AWS/Azure container option); "rhel-openssl-3.0.x"
  // is for Vercel's serverless functions (Amazon Linux 2023 runtime). All
  // three are generated so `prisma generate` at build time works everywhere
  // this app might run. If you switch the Docker base image to Alpine,
  // change debian-openssl-3.0.x to "linux-musl-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantType {
  INTERNAL
  CLIENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

// PENDING: self-registered, awaiting a tenant admin's approval (see the
// email flow design doc). ACTIVE: can log in. REJECTED/SUSPENDED: cannot —
// distinguished so admins can tell "we said no" from "was deactivated later".
// INVITED: an admin created this account directly (Team > Invite) — the
// person has an email link to accept but hasn't set their own password yet,
// so they can't log in normally until they do (see actions/admin.ts's
// inviteUser() and actions/auth.ts's acceptInvite()).
// UNVERIFIED: self-registered but hasn't confirmed the email is theirs yet
// (see registerClient()/verifyRegistrationOtp() in actions/auth.ts) — never
// shown in the admin approval queue, since there's no point asking an admin
// to review a registration nobody's confirmed is a real address yet.
enum UserStatus {
  UNVERIFIED
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  INVITED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SenderRole {
  CLIENT
  AGENT
  ADMIN
  SYSTEM
  BOT
  // A person added to one ticket via a guest invite link (see TicketGuest) —
  // never has a User row, so Message.senderId stays null for these and
  // Message.guestId identifies who wrote it instead.
  GUEST
}

// Z2.1 — Custom Fields (Support-owned). Values live in one polymorphic
// table keyed on (targetType, targetId); no Prisma relation to wrapper
// models (rule 3, docs/shared-platform-boundary.md §3), so USER/ORG
// targetIds are raw scalars. TICKET targetIds are Support-owned but
// still stored as raw scalars to keep one shape for all three scopes.
enum CustomFieldScope {
  USER
  ORG
  TICKET
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  DROPDOWN
  MULTISELECT
  // Z2.5 — reference another wrapper entity. Value stored as a raw scalar
  // id (`valueLookupId`) — no Prisma relation across the boundary. Sidebar
  // renders the referenced entity's name via a batch wrapper lookup.
  USER_LOOKUP
  ORG_LOOKUP
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  type         TenantType   @default(CLIENT)
  status       TenantStatus @default(ACTIVE)
  customDomain String?      @unique
  // M6.1.b — tenant-wide 2FA enforcement. When true, every user in
  // this tenant must enroll TOTP before their session cookie is minted.
  // Break-glass invariant: the setter must have MFA enrolled themselves,
  // enforced in actions/adminSecurity.ts.
  enforceMfa   Boolean      @default(false)
  // M9 — AI Intelligence Layer per-tenant knobs.
  //   aiEnabled: master switch. False → classification is skipped entirely.
  //   aiConfidenceThreshold: signals below this render muted in the agent UI
  //     (default 0.7 per spec §3).
  //   aiMonthlyTokenCap: soft cap on classification tokens; once exceeded,
  //     new messages hit cache-only until the monthly reset.
  //   aiTokensUsedThisMonth / aiTokensMonthResetAt: usage counters.
  //   aiAutoTranslate: M9.7. When true, non-tenant-language messages get a
  //     translated copy stored on the Message row.
  aiEnabled              Boolean   @default(true)
  aiConfidenceThreshold  Float     @default(0.7)
  aiMonthlyTokenCap      Int       @default(1000000)
  aiTokensUsedThisMonth  Int       @default(0)
  aiTokensMonthResetAt   DateTime  @default(now())
  aiAutoTranslate        Boolean   @default(false)
  aiPrimaryLanguage      String    @default("en")
  // M6.4 — tenant-wide SSO enforcement. When true, email/password login
  // is disabled for this tenant — only the IdP path works. Break-glass
  // invariant: at least one Super Admin must be flagged as break-glass
  // (their email/password auth stays active regardless of enforceSso).
  // Prevents an IdP misconfiguration from locking the tenant out.
  enforceSso   Boolean      @default(false)
  createdAt    DateTime     @default(now())

  branding                TenantBranding?
  chatbotConfig           ChatbotConfig?
  tickets                 Ticket[]
  categories              Category[]
  kbArticles              KbArticle[]
  kbSuggestions           KbSuggestion[]
  aiTools                 AiTool[]
  aiActionLogs            AiActionLog[]
  qaRubrics               QaRubric[]
  qaScores                QaScore[]
  chatConversations       ChatConversation[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  ticketGuests            TicketGuest[]
  surveyResponses         SurveyResponse[]
  savedViews              SavedView[]
  cannedResponses         CannedResponse[]
  macros                  Macro[]
  ticketViews             TicketView[]
  authCredentials         AuthCredential[]
  teamMemberLifecycles    TeamMemberLifecycle[]
  endUserLifecycles       EndUserLifecycle[]
  subjectAvatars          SubjectAvatar[]
  organizationSettings    OrganizationSettings[]
  subjectPreferences      SubjectPreference[]
  userSessions            UserSession[]
  loginActivity           LoginActivity[]
  notificationPreferences NotificationPreference[]
  encryptionKey           TenantEncryptionKey?
  identityProviders       TenantIdentityProvider[]
  scimTokens              ScimToken[]
  apiKeys                 ApiKey[]
  webhookSubscriptions    WebhookSubscription[]
  apiUsageLogs            ApiUsageLog[]
  intentTaxonomy          IntentTaxonomy[]
  aiClassificationCache   AiClassificationCache[]
  digestQueue             DigestQueue[]
  dataExportRequests      DataExportRequest[]
  accountDeletionRequests AccountDeletionRequest[]
  customFieldDefinitions  CustomFieldDefinition[]
  customFieldValues       CustomFieldValue[]
  customFieldOptions      CustomFieldOption[]
  ticketForms             TicketForm[]
  rules                   Rule[]
  ruleRunLogs             RuleRunLog[]
  escalationPaths         EscalationPath[]
  escalationLogs          EscalationLog[]
  slaPolicies             SlaPolicy[]
  businessCalendars       BusinessCalendar[]
  ticketSlas              TicketSla[]
  agentProfiles           AgentProfile[]
  autoAssignmentLogs      AutoAssignmentLog[]
  csatQueue               CsatQueue[]
  csatSettings            CsatSettings?
  savedReports            SavedReport[]
  ticketDailyRollups      TicketDailyRollup[]

  @@map("tenants")
}

model TenantBranding {
  tenantId       String  @id
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#FF6A00")
  accentColor    String  @default("#000000")
  productName    String  @default("Support")
  // The tenant's one dedicated inbound support address (e.g.
  // support@acme.com) — inbound webhook matches on this to route an email
  // to the right tenant before any ticket/user exists. Unique so two
  // tenants can never claim the same inbound mailbox.
  supportEmail   String? @unique
  // Provider-side inbound route/webhook id (Resend inbound route), stored
  // for reference/cleanup — not read by the app at request time.
  inboundRouteId String?
  emailFromName  String?
  emailDomain    String?
  customCss      String?

  @@map("tenant_branding")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model Category {
  id        String               @id @default(cuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean              @default(true)
  tickets   Ticket[]
  formLinks TicketFormCategory[]

  @@unique([tenantId, name])
  @@map("categories")
}

// ---------------------------------------------------------------------------
// Tickets
// ---------------------------------------------------------------------------

model Ticket {
  id                   String       @id @default(cuid())
  tenantId             String
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference            String
  // Short numeric id (e.g. "12707664") embedded in every notification
  // subject as "[#12707664]" — kept separate from `reference` because email
  // clients mangle subject lines, so inbound reply-matching needs the
  // simplest possible token to regex out. Globally unique (not per-tenant)
  // since the inbound webhook doesn't know the tenant until it's resolved
  // the ticket this number belongs to.
  ticketNumber         String       @unique
  // Message-ID of the last outbound notification for this ticket, so a
  // client's email reply can thread back via In-Reply-To/References as a
  // fallback when the subject tag itself got stripped.
  emailMessageId       String?
  title                String
  description          String
  status               TicketStatus @default(OPEN)
  priority             Priority     @default(MEDIUM)
  categoryId           String?
  category             Category?    @relation(fields: [categoryId], references: [id])
  // Dual-FK client — CLIENT (EndUser) or staff (TeamMember, Employee
  // Service Suite pattern). Raw scalars, no Prisma relations across the
  // boundary (rule 3, docs/shared-platform-boundary.md §3). CHECK
  // tickets_client_exclusive enforces num_nonnulls <= 1.
  clientEndUserId      String?
  clientTeamMemberId   String?
  assignedTeamMemberId String?
  // Ticket.organizationId denormalizes the client's Organization for
  // analytics/routing. Populated at backfill from users.companyId; on
  // new writes populated by looking up the EndUser's primary org via
  // the wrapper's matchOrganizationByEmailDomain / EndUser.organizationId.
  organizationId       String?
  source               String       @default("portal") // portal | chatbot | email
  firstReplyAt         DateTime?
  resolvedAt           DateTime?
  // Reopen tracking (analytics: reopen-rate KPI). reopenedAt is the most
  // recent reopen timestamp; reopenCount is a running total across the
  // ticket's lifetime, incremented whenever it transitions OUT of
  // RESOLVED/CLOSED back into an active status (see reopenTicket() and
  // updateTicket() in actions/tickets.ts).
  reopenedAt           DateTime?
  reopenCount          Int          @default(0)
  // Captured at creation time from the requester's HTTP request (portal/
  // chatbot only — email-sourced tickets have no live request, so both stay
  // null). clientCountry is an ISO 3166-1 alpha-2 code resolved from
  // clientIp via geoip-lite (offline lookup, no external API call) —
  // powers the analytics "clients by region" map/table. Never backfilled
  // for tickets created before this field existed.
  clientIp             String?
  clientCountry        String?
  // Z2.3: the ticket form the client picked (if any). Nullable — legacy
  // tickets and email-sourced ones have no form.
  ticketFormId         String?
  ticketForm           TicketForm?  @relation(fields: [ticketFormId], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  messages          Message[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  chatConversations ChatConversation[]
  notifications     Notification[]
  guests            TicketGuest[]
  surveyResponse    SurveyResponse?
  csatQueue         CsatQueue[]
  ticketViews       TicketView[]
  slas              TicketSla[]

  @@unique([tenantId, reference])
  @@index([tenantId, status, priority])
  @@index([tenantId, clientEndUserId])
  @@index([tenantId, clientTeamMemberId])
  @@index([tenantId, assignedTeamMemberId])
  @@index([tenantId, organizationId])
  @@map("tickets")
}

// One CSAT rating per ticket — see actions/csat.ts's submitCsatRating()
// (an unauthenticated, token-scoped action reached via the emailed
// "rate this ticket" link, actions/tickets.ts's updateTicket()). Resubmitting
// the same link overwrites the existing row rather than erroring, so
// ticketId is unique instead of having its own separate id-based history.
model SurveyResponse {
  id                      String                 @id @default(cuid())
  tenantId                String
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId                String                 @unique
  ticket                  Ticket                 @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // M5.4 — CSAT rows keep 1..5; NPS rows carry 0..10 in the same
  // column. Averages downstream just take the mean and the type
  // column distinguishes the scale. Splitting into two columns
  // would fork every downstream avg query — not worth it.
  rating                  Int
  comment                 String?
  // M5.4 — kind of survey this row represents. Determines the
  // rating scale (1..5 for CSAT, 0..10 for NPS) and the label
  // shown on analytics + moderation surfaces.
  surveyType              SurveyType             @default(CSAT)
  // M5.3 — moderation state so admins can hide abusive/erroneous
  // comments without dropping the rating (the numeric score still
  // counts). Rows default VISIBLE; a moderator flips to FLAGGED
  // or HIDDEN via /admin/csat.
  moderationStatus        SurveyModerationStatus @default(VISIBLE)
  moderatedByTeamMemberId String?
  moderatedAt             DateTime?
  createdAt               DateTime               @default(now())

  @@index([tenantId])
  @@index([tenantId, moderationStatus, createdAt])
  @@map("survey_responses")
}

// M5.4 — CSAT (1..5 stars) is the default; NPS (0..10) is the second
// variant. Same table, different scale + email template.
enum SurveyType {
  CSAT
  NPS
}

// M5.3 — moderation lifecycle for the free-text comment. A hidden
// comment is not shown outside /admin/csat; the numeric rating still
// contributes to averages.
enum SurveyModerationStatus {
  VISIBLE
  FLAGGED
  HIDDEN
}

// M5.1 — deferred CSAT send queue. Every enqueue schedules a
// (tenantId, ticketId) pair for `scheduledFor`; an Inngest cron
// drains rows whose scheduledFor <= now, mails them, and marks
// `sentAt`. Deferral lets the client's resolution notification
// land first (spec §3), and gives admins a configurable delay.
model CsatQueue {
  id            String     @id @default(cuid())
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId      String
  ticket        Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  surveyType    SurveyType @default(CSAT)
  scheduledFor  DateTime   @db.Timestamptz(3)
  sentAt        DateTime?  @db.Timestamptz(3)
  // Set when send fails and we give up — kept to explain the
  // absence in the admin surface. Retry loop is out of scope; a
  // failed row can be manually re-queued.
  failedAt      DateTime?  @db.Timestamptz(3)
  failureReason String?
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)

  // A ticket can accumulate multiple queue rows (e.g. re-resolved
  // after reopen). Uniqueness would drop the second one silently
  // and hide the intent. Keep them all; the send path skips a
  // ticket that already has a delivered row for the same type.
  @@index([tenantId, scheduledFor, sentAt])
  @@index([tenantId, ticketId])
  @@map("csat_queue")
}

// M5.1 — per-tenant CSAT settings. Support-owned (Tenant already
// lives here). Extending TenantBranding was tempting but branding
// is presentation and this is workflow; keeping them separate keeps
// each surface's schema honest.
model CsatSettings {
  tenantId     String     @id
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled      Boolean    @default(true)
  surveyType   SurveyType @default(CSAT)
  // Minutes to wait between ticket RESOLVED and the CSAT email.
  // Default 60 (1 hour) per spec §3 "let the resolution notification
  // land first". 0 = send immediately (opt-in for tenants who don't
  // want the delay).
  delayMinutes Int        @default(60)
  emailSubject String?
  emailBody    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("csat_settings")
}

// Z6.1 — Views. A saved filter/sort configuration an agent applies to the
// queue as their primary work surface. Support-owned; no Prisma relation
// to the wrapper TeamMember (raw scalar ownerTeamMemberId, per boundary
// rule 3). A nullable owner is reserved for shared views (Z6.5): NULL
// means tenant-shared. Filters are structured JSON so they're safe,
// portable, and eventually swappable to a different query layer (never
// raw SQL, per Z6 §3 "do NOT store view filter definitions as raw SQL").
model SavedView {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Owner of a personal view. NULL is reserved for Z6.5 shared views —
  // enforced today via app-layer checks that reject NULL on create.
  ownerTeamMemberId String?
  name              String
  // Structured filter JSON: { status?, priority?, categoryId?,
  // assignedToId? ("me" | "unassigned" | teamMemberId), search? }.
  // Kept as Json rather than columnized so new filter fields can land
  // without a migration on this table.
  filters           Json     @default("{}")
  // Sort JSON: { key: "updatedAt" | "createdAt" | "priority", dir: "asc" | "desc" }.
  sort              Json     @default("{\"key\":\"updatedAt\",\"dir\":\"desc\"}")
  // Marks this view as the agent's default (opens on /agent). Only one
  // per owner is allowed — enforced at the app layer in setDefaultView().
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, ownerTeamMemberId])
  @@map("saved_views")
}

// Z6.3 — Canned responses. Support-owned. Personal to a team member
// when ownerTeamMemberId is set; tenant-shared (Z6.5 shape) when null.
// `shortcut` is the /trigger the composer expands — unique per (tenant,
// owner) so agents don't collide with each other but shared responses
// live in a global namespace. Body may contain placeholders resolved
// via src/lib/placeholders.ts at expansion time.
model CannedResponse {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerTeamMemberId String?
  name              String
  shortcut          String
  body              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, ownerTeamMemberId, shortcut])
  @@index([tenantId, ownerTeamMemberId])
  @@map("canned_responses")
}

// Z6.4 — Macros. Structured JSON actions (not raw SQL — spec §3),
// applied against a specific ticket from the ticket-detail composer.
// Personal or tenant-shared (same nullable-owner pattern as SavedView).
// Every action's schema is validated by the macro engine before apply;
// unknown action types are rejected server-side.
model Macro {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerTeamMemberId String?
  name              String
  description       String?
  // Actions JSON. Shape: [{ type: "add_internal_note", body: string }
  //   | { type: "change_status", status: TicketStatus }
  //   | { type: "insert_reply_template", body: string }].
  actions           Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, ownerTeamMemberId])
  @@map("macros")
}

// Z6 DoD closure — per-agent ticket-view tracking. Powers real
// "unread" counts on views (a view's unread count = tickets in the
// view whose `updatedAt` is newer than the agent's `lastViewedAt`, or
// tickets the agent has never opened at all). Support-owned; no
// wrapper relation on `subjectId` (raw scalar per boundary rule 3).
model TicketView {
  subjectId    String
  ticketId     String
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  lastViewedAt DateTime @default(now())

  @@id([subjectId, ticketId])
  @@index([tenantId, subjectId])
  @@map("ticket_views")
}

model Message {
  id                 String       @id @default(cuid())
  tenantId           String
  ticketId           String
  ticket             Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Guest author: no wrapper counterpart (no account) — a guest never has an
  // EndUser row, so this identifies who wrote the message.
  guestId            String?
  guest              TicketGuest? @relation(fields: [guestId], references: [id])
  // Dual-FK author (wrapper): EndUser (client) or TeamMember (staff). Raw
  // scalars, no Prisma relations across the boundary (rule 3). CHECK
  // messages_sender_exclusive: num_nonnulls(senderEndUserId,
  // senderTeamMemberId, guestId) <= 1 — SYSTEM/BOT rows are all-null.
  senderEndUserId    String?
  senderTeamMemberId String?
  senderRole         SenderRole
  body               String
  isInternal         Boolean      @default(false)
  createdAt          DateTime     @default(now())

  // M9 — AI classification signals. Populated by
  // src/lib/inngest/functions/classify-message.ts on message create.
  // Only inbound (customer / guest) messages get classified — outbound
  // agent replies are skipped per M9 §3 (token spend).
  //
  //   aiIntent: matches a row from IntentTaxonomy.slug for this tenant.
  //     Null when confidence is below the threshold OR classification
  //     hasn't run yet.
  //   aiSentiment: "positive" | "neutral" | "negative" | "frustrated" |
  //     "angry". String not enum so the model can evolve without a
  //     migration.
  //   aiUrgency: "low" | "medium" | "high" | "critical".
  //   aiLanguage: BCP-47 tag (e.g. "en", "es-419").
  //   aiConfidence: 0.0–1.0 aggregate over all four dimensions. A single
  //     scalar keeps the M9.4 muted-vs-solid rendering rule simple.
  //   aiSignalsAt: when classification completed. Null → not yet run.
  //   aiOverriddenBySubjectId: set when an agent corrected a signal via
  //     the M9.4 override UI. Downstream (M9.5 rule engine, M9.6 routing)
  //     treats overridden values as final — no re-classification.
  //   aiTranslatedBody: M9.7. Populated when tenant.aiAutoTranslate is on
  //     and the message is in a language different from aiPrimaryLanguage.
  aiIntent                String?
  aiSentiment             String?
  aiUrgency               String?
  aiLanguage              String?
  aiConfidence            Float?
  aiSignalsAt             DateTime?
  aiOverriddenBySubjectId String?
  aiTranslatedBody        String?

  attachments Attachment[]

  @@index([tenantId, ticketId])
  @@index([tenantId, senderEndUserId])
  @@index([tenantId, senderTeamMemberId])
  @@index([tenantId, aiIntent])
  @@index([tenantId, aiSentiment])
  @@map("messages")
}

// M9.2 — per-tenant intent taxonomy. Admin editable at /admin/ai/intents.
// The taxonomy is injected into the classification prompt so results are
// bounded to the tenant's actual product surface — a SaaS billing tool's
// intents differ from a hardware helpdesk's.
model IntentTaxonomy {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug        String   // "login_issue", "billing", "how_to", "cancellation"
  label       String   // "Login issue" (display)
  description String   // Sent to the model as a hint
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("intent_taxonomy")
}

// M9 — content-hash keyed classification cache. Same message body →
// same signals, so we don't re-bill the LLM for a duplicate. Salted with
// the tenant's taxonomy version (via the taxonomyDigest column) so a
// tenant editing their taxonomy invalidates their cache without touching
// other tenants.
model AiClassificationCache {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contentHash     String   // sha256 of message body
  taxonomyDigest  String   // sha256 of the tenant's active taxonomy slugs
  intent          String?
  sentiment       String?
  urgency         String?
  language        String?
  confidence      Float
  tokensUsed      Int
  createdAt       DateTime @default(now())

  @@unique([tenantId, contentHash, taxonomyDigest])
  @@index([tenantId, createdAt])
  @@map("ai_classification_cache")
}

// M8 — Agentic AI Actions (tool registry). One row per allow-listed
// tool per tenant. The AI can only propose calls to enabled tools in
// this table; the executor rejects anything else (spec §3 pin).
//
// argsSchema is JSON-Schema-lite (see src/lib/ai/tools/validate.ts) —
// the executor validates every proposed call against this shape before
// touching the tool.
//
// kind is either INTERNAL (dispatch to a hard-coded handler in
// src/lib/ai/tools/builtins.ts — safest, no external network) or HTTP
// (outbound call to httpUrl with tenant-held credentials — never sent
// to the model). Only Super Admin / Admin can add HTTP tools; the
// admin UI enforces this.
//
// roleAllowlist limits which caller roles may invoke this tool. Stored
// as a JSON string[] (roles from AppRole: CLIENT | GUEST | AGENT |
// ADMIN | SUPER_ADMIN). Empty array = tool disabled for everyone but
// preserves the tool config so admins can turn it back on later.
model AiTool {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String   // e.g. "reset_password" — unique per tenant, snake_case
  description      String   // Sent to the model as the tool description
  kind             String   @default("INTERNAL") // INTERNAL | HTTP
  argsSchema       Json     // JSON-Schema-lite: { type: "object", properties: {...}, required: [...] }
  requiresApproval Boolean  @default(true)      // Default true (spec §3) — safe-by-default
  isEnabled        Boolean  @default(true)
  roleAllowlist    Json     @default("[]")      // string[] of AppRole values allowed to invoke
  httpUrl          String?                       // Only when kind = HTTP
  httpMethod       String?                       // GET | POST | PATCH | DELETE
  httpHeaders      Json?                          // Tenant-held headers; never sent to model
  retryLimit       Int      @default(2)          // Executor caps total attempts at retryLimit + 1
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  actionLogs       AiActionLog[]

  @@unique([tenantId, name])
  @@index([tenantId, isEnabled])
  @@map("ai_tools")
}

// M8 — AI action ledger. Every proposal, approval, rejection, execution
// attempt, success, and failure lands here. Read by the agent approval
// queue AND surfaced on ticket detail timelines.
//
// Status transitions (enforced in src/actions/aiActionQueue.ts +
// src/lib/ai/tools/executor.ts):
//   PROPOSED → EXECUTED               (requiresApproval=false, ok)
//   PROPOSED → FAILED                 (requiresApproval=false, error, over retryLimit)
//   PROPOSED → APPROVED → EXECUTED    (requiresApproval=true, agent approves, runs)
//   PROPOSED → APPROVED → FAILED      (agent approves, run errors)
//   PROPOSED → REJECTED               (agent rejects; tool never runs)
model AiActionLog {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  toolId               String
  tool                 AiTool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolName             String   // Denormalised — survives tool deletion (audit stability)
  conversationId       String?  // Chatbot origin (nullable — agent-copilot origin coming later)
  ticketId             String?  // Ticket context if any
  proposedByRole       String   // CLIENT | GUEST | AGENT | ADMIN | SUPER_ADMIN | SYSTEM
  proposedBySubjectId  String?  // Null when SYSTEM
  status               String   @default("PROPOSED") // PROPOSED | APPROVED | REJECTED | EXECUTED | FAILED
  argsJson             Json
  resultJson           Json?
  attempts             Int      @default(0)
  errorMessage         String?
  approvedBySubjectId  String?
  decidedAt            DateTime?
  executedAt           DateTime?
  createdAt            DateTime @default(now())

  @@index([tenantId, status])
  @@index([tenantId, ticketId])
  @@index([tenantId, createdAt])
  @@map("ai_action_logs")
}

// M11 — AI Quality Assurance. One active rubric per tenant; the
// scorer reads the currently-active row and grades every sent reply
// against it. dimensions is JSON so admins can add/remove axes
// without a schema migration — the shape is:
//   [
//     { key: "helpfulness", label: "Helpfulness", description: "...",
//       weight: 0.35, flagBelow: 3.0 },
//     ...
//   ]
// weight sums are not enforced — the scorer computes `overall` as a
// weight-normalised weighted mean, so any weights work.
model QaRubric {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  dimensions   Json     // array of { key, label, description, weight, flagBelow }
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  qaScores     QaScore[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("qa_rubrics")
}

// M11 — one QaScore per SENT message (spec §3: never score
// AI-drafted-but-not-sent messages). Uniqueness on messageId prevents
// double-scoring in the face of retry. senderRole is denormalised so
// dashboards + coaching views don't have to fan out to Message.
// isFlagged is derived at insert time from each dimension's flagBelow.
model QaScore {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rubricId              String
  rubric                QaRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  messageId             String   @unique
  ticketId              String
  // Denormalised — agent-side dashboards read these directly. Nullable
  // authorTeamMemberId covers BOT/SYSTEM/client-originated replies
  // (which are still scorable — the tenant may want to grade its own
  // AI). authorEndUserId set for CLIENT replies (rare — most tenants
  // score only outbound).
  authorTeamMemberId    String?
  authorEndUserId       String?
  senderRole            String   // AGENT | ADMIN | BOT | SYSTEM | CLIENT | GUEST
  // Per-dimension { helpfulness: {score: 4.2, rationale: "..."}, ... }
  // Rationales are internal-only — never surfaced to end users
  // (spec §3 "Do NOT display QA scores to end users").
  scoresJson            Json
  overall               Float
  isFlagged             Boolean  @default(false)
  flaggedReasons        Json?    // string[] of dimension keys that tripped flagBelow
  reviewStatus          String   @default("PENDING") // PENDING | REVIEWED | DISMISSED
  reviewedBySubjectId   String?
  reviewedAt            DateTime?
  tokensUsed            Int      @default(0)
  createdAt             DateTime @default(now())

  @@index([tenantId, isFlagged, reviewStatus])
  @@index([tenantId, authorTeamMemberId, createdAt])
  @@index([tenantId, ticketId])
  @@index([tenantId, createdAt])
  @@map("qa_scores")
}

model Attachment {
  id                     String   @id @default(cuid())
  tenantId               String
  ticketId               String
  ticket                 Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Null until the composer's "Send" actually posts the message the file was
  // staged for (see actions/attachments.ts uploadTicketAttachment /
  // actions/tickets.ts's postAgentReply|postClientReply) — an uploaded-but-
  // never-sent file just stays unlinked, still visible in Files & Links.
  messageId              String?
  message                Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // Dual-FK uploader (wrapper). Raw scalars — no Prisma relations across
  // the boundary (rule 3).
  uploadedByEndUserId    String?
  uploadedByTeamMemberId String?
  // Storage object PATH, not a public URL — this bucket is private (ticket
  // attachments aren't "public by nature" like branding logos/avatars are).
  // Resolved to a short-lived signed URL on read; see lib/storage.ts.
  fileUrl                String
  fileName               String
  mimeType               String
  sizeBytes              Int
  uploadedAt             DateTime @default(now())

  @@index([tenantId, ticketId])
  @@index([messageId])
  @@index([tenantId, uploadedByEndUserId])
  @@index([tenantId, uploadedByTeamMemberId])
  @@map("attachments")
}

// A person added to exactly one ticket via an emailed magic link — no
// account, no password, no session cookie. invitedById is the staff/client
// User who added them; the guest's own identity is just email (+ optional
// name) carried on this row and denormalized onto any Message they send
// (Message.guestId). tokenHash is sha256 of the raw token that goes in the
// email; only the hash is ever stored (same pattern as password-reset,
// except this one needs server-side state since it's revocable/long-lived
// rather than a short single-use JWT).
model TicketGuest {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId              String
  ticket                Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  email                 String
  name                  String?
  tokenHash             String    @unique
  // Dual-FK inviter (wrapper). Raw scalars.
  invitedByEndUserId    String?
  invitedByTeamMemberId String?
  createdAt             DateTime  @default(now())
  revokedAt             DateTime?

  messages Message[]

  @@index([tenantId, ticketId])
  @@index([tenantId, invitedByEndUserId])
  @@index([tenantId, invitedByTeamMemberId])
  @@map("ticket_guests")
}

// Server-side state for the one-time email code verified at invite
// acceptance (first login only — see actions/auth.ts's acceptInvite() /
// verifyLoginOtp()). Deliberately NOT a JWT like session/reset tokens,
// since a code needs to be matched against a value already emailed out
// (can't just re-derive/re-verify a signature the way a stateless token
// works) and single-use tracked independent of any password change.
model LoginOtp {
  id           String    @id @default(cuid())
  tenantId     String
  // Dual-FK subject (wrapper). Exactly one must be non-null (CHECK
  // login_otps_subject_present enforces at DB level). Raw scalars.
  endUserId    String?
  teamMemberId String?
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([endUserId])
  @@index([teamMemberId])
  @@map("login_otps")
}

model AuditLog {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId          String?
  ticket            Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Dual-FK actor (wrapper). Raw scalars. CHECK audit_logs_actor_exclusive:
  // num_nonnulls(actorEndUserId, actorTeamMemberId) <= 1 — SYSTEM rows all-null.
  actorEndUserId    String?
  actorTeamMemberId String?
  action            String // STATUS_CHANGE | PRIORITY_CHANGE | ASSIGN | REPLY | REOPEN | ...
  fromValue         String?
  toValue           String?
  createdAt         DateTime @default(now())

  @@index([tenantId, ticketId])
  @@index([tenantId, actorEndUserId])
  @@index([tenantId, actorTeamMemberId])
  @@map("audit_logs")
}

// In-app notification bell (nav-bar.tsx). Deliberately separate from the
// email system (lib/email/) — a notification is a personal, per-user inbox
// item ("you were assigned a ticket"), not a tenant-wide log like AuditLog
// or an outbound message like the email templates. Written via createMany()
// everywhere (see lib/notifications.ts), never .create() — Prisma's
// .create() always does an implicit RETURNING checked against SELECT
// policies, and the actor creating a notification (e.g. a client replying)
// is essentially never the same user as the notification's recipient (the
// assigned agent), so that RETURNING check would fail under RLS the same
// way the audit_logs one originally did (see rls_policies.sql). createMany()
// has no RETURNING, sidestepping the problem entirely — we don't need the
// created row back anyway.
model Notification {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Dual-FK recipient (wrapper). Exactly one must be non-null (CHECK
  // notifications_recipient_present).
  recipientEndUserId    String?
  recipientTeamMemberId String?
  type                  String // TICKET_REPLY | STATUS_CHANGE | ASSIGNED | REGISTRATION_PENDING | REGISTRATION_APPROVED | REGISTRATION_REJECTED
  title                 String
  body                  String?
  ticketId              String?
  ticket                Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  isRead                Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([tenantId, recipientEndUserId, isRead, createdAt])
  @@index([tenantId, recipientTeamMemberId, isRead, createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Auth + lifecycle (Z1.8 Set B — see docs/adrs/adr-001-z1-8-auth-model-set-b.md)
// ---------------------------------------------------------------------------
//
// Support-owned tables introduced in Z1.8 to move password + lifecycle state
// off the legacy `users` table ahead of Z1.5's drop. Set B (per ADR-001):
// Support owns its auth surface; wrapper stays identity-only.
//
// Design notes:
//   - subjectEndUserId / subjectTeamMemberId / subjectId are raw scalar
//     columns (not Prisma relations), matching the Z1.4a dual-FK precedent —
//     enforcement is via CHECK constraint on auth_credentials and via
//     single-column PK on the lifecycle tables. See
//     docs/shared-platform-boundary.md §3 rule 3. Cascade ownership stays
//     on the wrapper's team.
//   - status uses the existing UserStatus enum, preserving Team & Roles v2
//     PR #21's 6-state model as ADR-001 committed to.
//   - AuthCredential.id is a fresh cuid at row-creation time; matches to
//     legacy `users.id` go via subjectEndUserId or subjectTeamMemberId
//     (which ARE preserved from Z1.3), never by direct id comparison. See
//     prisma/z1_8a_migration.sql header for the drift-check convention.
//   - Dual-write with legacy `users` runs from Z1.8a through Z1.5. Legacy
//     stays read-authoritative until Z1.5 removes it.

// M6.2/M6.3 — one IdP per tenant per protocol (SAML or OIDC).
// The `config` blob holds protocol-specific fields serialized as JSON:
//
//   SAML:  { entityId, ssoUrl, sloUrl?, cert (v2: envelope ciphertext),
//            wantAssertionsSigned?, signatureAlgorithm? }
//   OIDC:  { issuer, clientId, clientSecret (v2: envelope ciphertext),
//            redirectUri, scopes? }
//
// groupMappings is a normalized JSON blob:
//   [{ idpGroup: "stralis-admins", roleName: "Admin" }, ...]
// See M6.7 for the mapping resolver semantics.
//
// breakGlassOnly: when true, the entire tenant can bypass this IdP
// via email/password AFTER an SSO misconfiguration — used during
// the "IdP unreachable, use break-glass" recovery path.
model TenantIdentityProvider {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind           String   // "SAML" | "OIDC"
  displayName    String   @default("Sign in with SSO")
  isActive       Boolean  @default(true)
  config         Json
  groupMappings  Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, kind])
  @@index([tenantId])
  @@map("tenant_identity_providers")
}

// M6.5 — SCIM API tokens. Bearer-authed via the Authorization header.
// `tokenHash` is bcrypt of the emitted token (the raw token is shown
// exactly once on create, same UX as GitHub personal-access-tokens).
// `revokedAt` non-null → hard-fail all requests from this token.
model ScimToken {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash   String
  name        String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([tenantId])
  @@map("scim_tokens")
}

// M7.1 — generic API keys for the public v1 API. Same primitive as
// ScimToken (bcrypt-hashed bearer, per-tenant, revocable) but with
// scopes + creator attribution + kind so a fired employee's key stops
// working immediately without a per-request role fetch.
//
// scopes: JSON array of kebab-case strings ("tickets:read", "users:write").
//   See src/lib/api/scopes.ts for the canonical catalog.
// createdBySubjectId: the TeamMember whose permissions bounded the scope
//   set at create time. On every request, we verify that subject is still
//   ACTIVE — if their lifecycle flipped to SUSPENDED, every key they
//   created stops working automatically.
// prefix: first 8 chars of the raw token, plaintext, for UI display + a
//   fast pre-filter in verifyApiKey (bcrypt-scanning every live key
//   doesn't scale past ~50 keys/tenant; scanning by prefix is O(1)).
model ApiKey {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                 String
  prefix               String
  tokenHash            String
  scopes               Json      @default("[]")
  createdBySubjectId   String
  createdAt            DateTime  @default(now())
  lastUsedAt           DateTime?
  revokedAt            DateTime?

  @@index([tenantId, prefix])
  @@index([tenantId, revokedAt])
  @@map("api_keys")
}

// M7.4 — outbound webhook subscription. Each subscription targets one
// external URL and a set of event types (kebab-case, e.g. "ticket.created",
// "ticket.resolved"). The `secret` is HMAC-shared with the recipient;
// stored envelope-encrypted (v2:) per M6.1.a.
//
// failCount tracks consecutive delivery failures; when it exceeds the
// disable threshold (default 20 attempts over ~24h backoff window), the
// subscription is marked disabled and the tenant is notified.
model WebhookSubscription {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url            String
  events         Json      @default("[]")
  secret         String    // envelope-encrypted
  isActive       Boolean   @default(true)
  failCount      Int       @default(0)
  disabledAt     DateTime?
  disabledReason String?
  createdAt      DateTime  @default(now())
  lastDeliveredAt DateTime?
  createdBySubjectId String

  @@index([tenantId, isActive])
  @@map("webhook_subscriptions")
}

// M7.6 — per-request usage log. Kept in a hot append-only table; older
// rows drained by the M13.gap3 daily rollup pattern (out-of-band; not
// part of M7.6 initial ship). Cardinality: ~O(req_per_day × retention).
model ApiUsageLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeyId     String?  // null for anonymous or invalid-key rejections
  method       String
  path         String
  statusCode   Int
  durationMs   Int
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, apiKeyId, createdAt])
  @@map("api_usage_logs")
}

// M6.1.a — per-tenant DEK for envelope-encrypted secrets (mfaSecret today;
// SAML certs and SCIM tokens once M6.2/M6.5 land). Wrapped with the app-
// level KEK from MFA_SECRET_KEY. See src/core/auth/envelope-crypto.ts
// for the wire format and rotation model.
model TenantEncryptionKey {
  tenantId   String   @id
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wrappedDek String
  createdAt  DateTime @default(now())

  @@map("tenant_encryption_keys")
}

model AuthCredential {
  id                      String    @id @default(cuid())
  tenantId                String
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectEndUserId        String?
  subjectTeamMemberId     String?
  passwordHash            String
  passwordChangedAt       DateTime?
  // M21.2 — email-change flow. `pendingEmail` is the address the confirmation
  // link resolves to; cleared on confirm (or by a fresh request superseding it).
  // Held Support-side because the wrapper email column stays authoritative
  // for identity; nothing outside this flow reads pendingEmail.
  pendingEmail            String?
  pendingEmailRequestedAt DateTime?
  // M6.1 — TOTP 2FA. `mfaSecret` holds the ciphertext produced by
  // src/core/auth/mfa-crypto.ts (v1: AES-256-GCM with MFA_SECRET_KEY).
  // Never plaintext. `mfaEnabledAt` gates login challenge — its
  // presence, not `mfaSecret != null`, is what triggers the second-step
  // prompt, so an enroll flow that starts and drops half-way cannot
  // lock the user out. `mfaBackupCodesHash` holds up to 8 bcrypt-hashed
  // one-time codes; each is spliced out on use.
  mfaSecret               String?
  mfaEnabledAt            DateTime?
  mfaBackupCodesHash      String[]
  // M6.4 — break-glass flag. When the tenant has enforceSso=true, every
  // user must sign in via the IdP EXCEPT users with isBreakGlass=true.
  // The invariant that enforceSso can only be turned on if at least one
  // break-glass Super Admin exists lives in actions/tenantSecurity.ts.
  isBreakGlass            Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([tenantId, subjectEndUserId])
  @@index([tenantId, subjectTeamMemberId])
  @@map("auth_credentials")
}

model TeamMemberLifecycle {
  subjectId    String     @id
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       UserStatus
  invitedAt    DateTime?
  invitedById  String?
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?
  lastActiveAt DateTime?
  // Z3.3 — free-form agent notes about this person, persisted across
  // every ticket they touch. Distinct from Message.isInternal (per-ticket
  // internal notes). Support-owned because we can't extend wrapper DTOs.
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, status])
  @@map("team_member_lifecycle")
}

// Z4 — Support-owned org sidecar. Wrapper Organization is off-limits
// (rule 3, docs/shared-platform-boundary.md §3), so Support keeps its
// own per-org settings row: agent notes that persist across the org's
// tickets, plus placeholder foreign keys for the SLA policy and
// business-hours override that M2 will introduce. Both id columns are
// raw strings — no relation to non-existent tables — so the schema
// stays valid pre-M2, and switching them to real relations after M2
// ships is a schema-only change with no data rewrite.
model OrganizationSettings {
  organizationId  String   @id
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes           String?
  slaPolicyId     String?
  businessHoursId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("organization_settings")
}

// Z1.7 — Support-owned avatar store. Same Set B rationale as
// AuthCredential + *Lifecycle: wrapper stays identity-only, Support
// owns UI concerns. Keyed by subjectId (unique across end_users /
// team_members thanks to Z1.3 preserved-ids). Written by
// actions/profile.ts's uploadProfilePicture; read by getSessionUser
// and by list views via lib/avatars.ts's getAvatarUrlsByIds().
model SubjectAvatar {
  subjectId String   @id
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("subject_avatars")
}

// M21.1 — Support-owned user preferences (timezone, language). Same Set
// B pattern as SubjectAvatar: wrapper stays identity-only, Support owns
// UI concerns. Keyed by subjectId (unique across end_users / team_members
// thanks to Z1.3 preserved-ids). Density / theme / defaultLanding are
// reserved for M21.5 (Appearance tab) but the columns land here so a
// second migration isn't needed.
model SubjectPreference {
  subjectId      String   @id
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timezone       String?
  language       String?
  theme          String?
  density        String?
  defaultLanding String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@map("subject_preferences")
}

// M21.3 — per-device session tracking. Every issued session cookie
// carries a `sessionId` claim; getSessionUser rejects any cookie whose
// row is missing or expired. Revoking a session = deleting its row.
// `subjectKind` mirrors the SessionPayload TS union — kept as a plain
// string column (not a Prisma enum) so this table works with either
// end_users or team_members without a wrapper-owned enum.
model UserSession {
  id           String   @id
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId    String
  subjectKind  String
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  @@index([tenantId, subjectId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// M21.3 — append-only login history. Populated in actions/auth.ts's
// login() on every successful sign-in. Displayed in the Security tab.
// Kept separate from UserSession so revoking a session doesn't erase the
// audit trail.
model LoginActivity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId   String
  subjectKind String
  userAgent   String?
  ipAddress   String?
  country     String?
  createdAt   DateTime @default(now())

  @@index([tenantId, subjectId, createdAt])
  @@map("login_activity")
}

// M21.4 — per-subject notification preferences. Each column gates one
// specific event; the `digestMode` column swaps real-time email delivery
// for a queued daily summary drained by an Inngest job. Every column
// defaults to `true` so a user who has never touched the tab keeps
// getting the same emails they got pre-M21.4.
model NotificationPreference {
  subjectId          String   @id
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailTicketCreated Boolean  @default(true)
  emailTicketReply   Boolean  @default(true)
  emailStatusChange  Boolean  @default(true)
  emailAssigned      Boolean  @default(true)
  emailCsatRequest   Boolean  @default(true)
  inAppTicketReply   Boolean  @default(true)
  inAppStatusChange  Boolean  @default(true)
  inAppAssigned      Boolean  @default(true)
  digestMode         String   @default("INSTANT")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@map("notification_preferences")
}

// M21.4 — queued email events for subjects whose digestMode is DAILY.
// Drained by the daily-digest Inngest job (src/lib/inngest/functions/
// send-daily-digests.ts); rows are deleted once bundled into an email.
model DigestQueue {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId String
  eventKey  String
  subject   String
  body      String
  ticketRef String?
  ticketUrl String?
  createdAt DateTime @default(now())

  @@index([tenantId, subjectId, createdAt])
  @@map("digest_queue")
}

// M21.6 — data export requests. Kicked off from the Danger Zone; the
// build-data-export Inngest job collects the subject's records into
// `payload` (Jsonb), then a signed token gives the download route
// (`/api/data-export/[token]`) permission to serve them. `expiresAt`
// is enforced at read time — the row lingers past that for
// audit/history but the download won't work.
model DataExportRequest {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId String
  status    String    @default("PENDING")
  payload   Json?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, subjectId])
  @@map("data_export_requests")
}

// M21.6 — account deletion requests. The user submits (last-Super-Admin
// guard applied at submit time so a doomed request never lands in the
// queue). Rows in PENDING appear on the admin's approval page; on
// APPROVED the user is actually deleted, on REJECTED they stay active.
model AccountDeletionRequest {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId    String
  reason       String?
  status       String    @default("PENDING")
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, status, createdAt])
  @@map("account_deletion_requests")
}

model EndUserLifecycle {
  subjectId    String     @id
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       UserStatus
  invitedAt    DateTime?
  invitedById  String?
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?
  lastActiveAt DateTime?
  // Z3.3 — see TeamMemberLifecycle.notes.
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, status])
  @@map("end_user_lifecycle")
}

// ---------------------------------------------------------------------------
// Z2.1 — Custom Fields
//
// One definition table + one polymorphic value table. `key` is immutable
// (label/isRequired/position can change); placeholder resolvers
// (`{{ticket.custom_fields.<key>}}`) and integrations depend on the key
// staying stable. Uniqueness is (tenantId, scope, key) so USER and TICKET
// can both have a "priority" key without collision.
//
// Deactivation, not deletion: definitions carry `isActive` — values are
// kept so historical tickets keep their sidebar data. See Z2 spec §3.
// ---------------------------------------------------------------------------

model CustomFieldDefinition {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope       CustomFieldScope
  type        CustomFieldType
  // Immutable after create — see §3 of the Z2 spec. Lowercase snake_case,
  // cannot start with a digit; enforced at the action layer (Zod) and
  // the unique index below.
  key         String
  label       String
  description String?
  isActive    Boolean          @default(true)
  isRequired  Boolean          @default(false)
  // Display order within a (scope) column on admin/detail sidebars.
  position    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  values     CustomFieldValue[]
  options    CustomFieldOption[]
  formFields TicketFormField[]

  @@unique([tenantId, scope, key])
  @@index([tenantId, scope, isActive])
  @@map("custom_field_definitions")
}

// Z2.2 — Options for DROPDOWN / MULTISELECT fields.
//
// `value` is the stable identifier (like the key on a definition — used by
// placeholder resolvers, trigger conditions, and integrations). `label` is
// the display text and is freely renamable. Uniqueness is per definition
// so two fields can each have an option called "high" without collision.
//
// `implicitTag` is Zendesk-style: selecting this option can apply a tag to
// the entity. Stored as free text (not a Tag FK) because (a) the mapping
// should survive tag renames, and (b) TICKET-scoped fields want this too
// but ticket tagging isn't yet a first-class concept — trigger/rule
// engines (Z8) will consume this string and do the tag write.
model CustomFieldOption {
  id                String                @id @default(cuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  value             String
  label             String
  position          Int                   @default(0)
  implicitTag       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([fieldDefinitionId, value])
  @@index([tenantId])
  @@index([fieldDefinitionId, position])
  @@map("custom_field_options")
}

// ---------------------------------------------------------------------------
// Z2.3 — Ticket Forms
//
// A form is a curated ordered subset of TICKET-scoped CustomFieldDefinitions
// pinned to zero or more Categories. When a client picks a category on the
// portal, the first (position-ordered, active) TicketForm whose
// `categories` list contains that category is used to render extra fields.
// If no form pins a category, no custom fields are shown.
//
// Only TICKET-scoped definitions can be added to a form (enforced in the
// action layer). USER/ORG fields live only on the entity's own sidebar.
// ---------------------------------------------------------------------------

model TicketForm {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields     TicketFormField[]
  categories TicketFormCategory[]
  tickets    Ticket[]

  @@index([tenantId, isActive])
  @@map("ticket_forms")
}

model TicketFormField {
  id                 String                @id @default(cuid())
  tenantId           String
  ticketFormId       String
  ticketForm         TicketForm            @relation(fields: [ticketFormId], references: [id], onDelete: Cascade)
  fieldDefinitionId  String
  fieldDefinition    CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  position           Int                   @default(0)
  // Overrides CustomFieldDefinition.isRequired for this form only. Lets a
  // form say "on THIS intake path we don't need service_tier" even if the
  // sidebar edit view still marks it required.
  isRequiredOverride Boolean?
  // Z2.4 — conditional visibility. When set, this field only shows on the
  // form if the sibling field's value equals `visibleWhenValue` (string
  // equality — Z2 spec §3 limits us to single-condition rules).
  visibleWhenFieldId String?
  visibleWhenValue   String?

  @@unique([ticketFormId, fieldDefinitionId])
  @@index([tenantId])
  @@index([ticketFormId, position])
  @@map("ticket_form_fields")
}

model TicketFormCategory {
  ticketFormId String
  ticketForm   TicketForm @relation(fields: [ticketFormId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantId     String

  @@id([ticketFormId, categoryId])
  @@index([tenantId, categoryId])
  @@map("ticket_form_categories")
}

model CustomFieldValue {
  id                String                @id @default(cuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  // Polymorphic target — mirrors the definition's scope. targetId is a
  // raw scalar for USER (end_users.id) / ORG (organizations.id) because
  // those are wrapper-owned; TICKET (tickets.id) is Support-owned but
  // stored the same way so all three scopes share one query shape.
  targetType        CustomFieldScope
  targetId          String
  // Typed value columns. Exactly one is populated per row, matching the
  // definition's `type`. A CHECK constraint in the migration enforces
  // this at the DB level; the actions layer enforces it in Zod first.
  valueText         String?
  valueNumber       Decimal?              @db.Decimal(20, 6)
  valueDate         DateTime?
  valueBoolean      Boolean?
  // Z2.2: single-option pick for DROPDOWN.
  valueOptionId     String?
  // Z2.2: multi-option pick for MULTISELECT. Default `[]` so the CHECK
  // constraint's "empty array == not set" convention works out of the box
  // for TEXT/NUMBER/etc. rows. Postgres text[]; queryable via `@>`.
  valueOptionIds    String[]              @default([])
  // Z2.5: id of the referenced wrapper entity (EndUser for USER_LOOKUP,
  // Organization for ORG_LOOKUP). Raw scalar — no Prisma relation.
  valueLookupId     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([fieldDefinitionId, targetId])
  @@index([tenantId, targetType, targetId])
  @@map("custom_field_values")
}

// ---------------------------------------------------------------------------
// AI / Knowledge base / Chatbot
// ---------------------------------------------------------------------------

model KbArticle {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  body        String
  isPublished Boolean   @default(false)
  // M10.3 — set by an admin's Suggestions-tab accept OR by the "mark
  // reviewed" action on a stale-flagged article. Distinct from updatedAt
  // (which any edit bumps) so freshness is tracked by intent, not touch.
  reviewedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  chunks      KbChunk[]
  suggestions KbSuggestion[]

  @@index([tenantId])
  @@map("kb_articles")
}

// M10 — self-learning KB. The nightly clustering job files drafts
// (status=PENDING) grounded in resolved-ticket clusters that had no
// strong KB match. Admin review is mandatory before anything hits the
// live KB (spec §3 "do NOT auto-publish"). Rejection memory (§M10.4)
// uses sourceDigest: the sha256 of the sorted source-ticket-ids. Same
// digest + REJECTED → skip re-suggest until materially more content.
model KbSuggestion {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status               String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  title                String
  body                 String
  sourceTicketIds      Json     // string[] — 1..N ticket ids that seeded the draft
  sourceDigest         String   // sha256 of sorted sourceTicketIds; dedup + rejection memory
  reason               String?  // e.g. "cluster of N tickets with no KB coverage"
  rejectionReason      String?  // filled when admin rejects
  decidedAt            DateTime?
  decidedBySubjectId   String?
  publishedArticleId   String?
  publishedArticle     KbArticle? @relation(fields: [publishedArticleId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())

  @@unique([tenantId, sourceDigest])
  @@index([tenantId, status])
  @@map("kb_suggestions")
}

model KbChunk {
  id        String    @id @default(cuid())
  tenantId  String
  articleId String
  article   KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  // TODO(decision): swap to pgvector `vector(1536)` once the AI/M5 milestone
  // is built and a Postgres with the pgvector extension is provisioned.
  // Storing as a plain float array keeps local dev unblocked without it.
  embedding Json?

  @@index([tenantId])
  @@map("kb_chunks")
}

model ChatbotConfig {
  tenantId      String  @id
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled     Boolean @default(true)
  persona       String  @default("a friendly support assistant")
  systemPrompt  String?
  deflectFirst  Boolean @default(true)
  escalateAfter Int     @default(3)
  allowedTopics String?

  @@map("chatbot_configs")
}

model ChatConversation {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Dual-FK subject (wrapper). Raw scalars.
  endUserId    String?
  teamMemberId String?
  status       String        @default("active") // active | escalated | closed
  ticketId     String?
  ticket       Ticket?       @relation(fields: [ticketId], references: [id])
  createdAt    DateTime      @default(now())
  messages     ChatMessage[]

  @@index([tenantId])
  @@index([tenantId, endUserId])
  @@index([tenantId, teamMemberId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           SenderRole
  body           String
  citations      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ===========================================================================
// STRALIS SHARED PLATFORM — REFERENCE MODELS (Z1: Six-Object Model Refactor)
// ===========================================================================
//
// These 9 tables + 3 enums are OWNED BY THE STRALIS SHARED PLATFORM REPO
// (../Stralis Shared Platform/prisma/schema.prisma). Both repos connect to
// the same physical Postgres database (see the Shared Platform's ADR-004,
// "Single Public Schema Ownership by Convention"). Ownership is enforced by
// docs + code review, not the database — every table below lives in
// Postgres's public schema, same as this repo's own tables.
//
// WHY THEY'RE MIRRORED HERE:
//   - So this repo's `prisma generate` produces TypeScript types + a working
//     Prisma Client for these models, letting server actions query and
//     mutate them the same way any local model works.
//   - This is the pre-M7 arrangement: this repo talks to the shared tables
//     via Prisma directly through the wrapper service in
//     src/lib/shared-platform/. Once the Shared Platform's Public API (M7)
//     ships, the wrapper flips from Prisma to HTTP fetch and the models
//     below can be removed. See docs/shared-platform-boundary.md.
//
// RULES:
//   1. NEVER edit a model or enum in this block. If the Shared Platform
//      ships schema changes to core, run `npm run pull-core` (which for now
//      is a manual copy-paste from the Shared Platform's schema.prisma) and
//      commit the diff — do not hand-edit.
//   2. NEVER run `prisma migrate dev` or `prisma db push` in this repo
//      while these models are present unless every model matches the DB's
//      current state exactly. If they match, `db push` is a no-op and
//      that's fine; if they don't, `db push` will corrupt the shared DB.
//   3. NEVER introduce a Prisma relation FROM a Support-owned model TO one
//      of the shared models (e.g. don't add `endUser EndUser @relation(...)`
//      on Ticket). FKs cross the boundary; Prisma relations don't. Use raw
//      scalar `endUserId String?` columns and resolve via the wrapper.
//   4. Tenant is NOT mirrored here because it stays owned by THIS repo.
//      The shared platform stores tenantId as a plain scalar and enforces
//      the FK at the SQL level (see their migration.sql). Migrating Tenant
//      to the shared platform is a deliberate future ADR — not decided as
//      a side effect of Z1. See docs/shared-platform-boundary.md.
//
// If any of these rules would need to be broken to ship a feature, STOP and
// escalate — either the boundary is wrong (unlikely) or the feature is
// designed against it (fixable).

enum TicketAccessScope {
  ALL
  GROUPS
  ASSIGNED_ONLY
}

enum TagTargetType {
  END_USER
  TEAM_MEMBER
  ORGANIZATION
  // Z8 — ticket tagging so rule/macro `add_tag` actions can target the
  // ticket itself (Zendesk parity). Existing rows for users/orgs are
  // unaffected; the tag_assignments unique constraint keys off
  // targetType so a ticket + user + org can each hold the same tag name
  // independently.
  TICKET
}

enum AuditActorType {
  TEAM_MEMBER
  SYSTEM
}

model Organization {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  endUsers           EndUser[]
  endUserMemberships EndUserOrganization[]

  @@unique([tenantId, name])
  @@index([tenantId, domain])
  @@map("organizations")
}

model EndUser {
  id             String        @id @default(cuid())
  tenantId       String
  email          String
  name           String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organizationMemberships EndUserOrganization[]

  @@unique([tenantId, email])
  @@index([tenantId, organizationId])
  @@map("end_users")
}

model EndUserOrganization {
  endUserId      String
  endUser        EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId       String
  createdAt      DateTime     @default(now())

  @@id([endUserId, organizationId])
  @@index([tenantId])
  @@map("end_user_organizations")
}

model TeamMember {
  id                String            @id @default(cuid())
  tenantId          String
  email             String
  name              String?
  roleId            String
  role              Role              @relation(fields: [roleId], references: [id])
  ticketAccessScope TicketAccessScope @default(ASSIGNED_ONLY)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  groupMemberships TeamMemberGroup[]

  @@unique([tenantId, email])
  @@index([tenantId, roleId])
  @@map("team_members")
}

model Group {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships TeamMemberGroup[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("groups")
}

model TeamMemberGroup {
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  groupId      String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tenantId     String
  createdAt    DateTime   @default(now())

  @@id([teamMemberId, groupId])
  @@index([tenantId])
  @@map("team_member_groups")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  isCustom    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamMembers TeamMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#7A7A7A")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments TagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model TagAssignment {
  id         String        @id @default(cuid())
  tenantId   String
  tagId      String
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  targetType TagTargetType
  targetId   String
  createdAt  DateTime      @default(now())

  @@unique([tenantId, tagId, targetType, targetId])
  @@index([tenantId, targetType, targetId])
  @@map("tag_assignments")
}

model CoreAuditLog {
  id           String         @id @default(cuid())
  tenantId     String
  actorId      String?
  actorType    AuditActorType
  action       String // CREATE | UPDATE | DELETE | ASSIGN | ...
  resourceType String // "Organization" | "EndUser" | "TeamMember" | "Group" | "Role" | "Tag" | ...
  resourceId   String
  fromValue    Json?
  toValue      Json?
  createdAt    DateTime       @default(now())

  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, createdAt])
  @@map("core_audit_logs")
}

