// ---------------------------------------------------------------------------
// Z8 — Workflow Engine (Triggers, Automations, Escalation Paths)
// ---------------------------------------------------------------------------
// One Rule table for Triggers + Automations — they share the same
// condition/action vocabulary; only the firing pattern differs. The
// `kind` column disambiguates and drives both the query filter (only
// TRIGGERs load on ticket events; only AUTOMATIONs load on the scheduler
// tick) and the editor route.

enum RuleKind {
  TRIGGER
  AUTOMATION
}

enum TriggerEventType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_REPLIED
  STATUS_CHANGED
  PRIORITY_CHANGED
  SLA_WARNING
  SLA_BREACH
  TAG_ADDED
  INTENT_DETECTED
  SENTIMENT_DETECTED
}

model Rule {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          RuleKind
  name          String
  description   String?
  active        Boolean           @default(true)
  // TRIGGER-only: which event fires this rule. NULL for AUTOMATION.
  triggerEvent  TriggerEventType?
  // AUTOMATION-only: interval hours (simple cadence — cron would be
  // more flexible but harder to reason about for the DoD's
  // "batch-processed, no ticket touched more than once per run").
  intervalHours Int?
  // Shape: { match: "all" | "any", conditions: [{ field, op, value }] }
  conditions    Json
  // Shape: [{ type, ...params }] — see src/lib/rule-schema.ts
  actions       Json
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lastRunAt     DateTime?
  runLogs       RuleRunLog[]

  @@index([tenantId, kind, active])
  @@index([tenantId, kind, triggerEvent])
  @@map("rules")
}

model RuleRunLog {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ticketId       String?
  // "matched" | "skipped_conditions" | "skipped_cap" | "action_failed"
  outcome        String
  ranActionCount Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([tenantId, ruleId, createdAt])
  @@map("rule_run_logs")
}

enum EscalationDestKind {
  TEAM
  WEBHOOK
  EMAIL
  INTEGRATION
}

enum EscalationStatus {
  SUCCESS
  FAILED
}

model EscalationPath {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label          String
  // Heroicon key, e.g. "alertTriangle" — free-form so a future icon
  // set swap doesn't need a schema migration.
  icon           String?
  // Category ids that reveal this button. Empty array = show on
  // every ticket. Stored as Json because Prisma+Postgres arrays of
  // FK strings are noisy to declare and this is a small opaque list.
  categoryIds    Json               @default("[]")
  destKind       EscalationDestKind
  // Shape depends on destKind:
  //   TEAM:        { groupId, alsoSetPriority?, alsoAddTag? }
  //   WEBHOOK:     { url, secret? }
  //   EMAIL:       { toEmails: string[], subject?, template? }
  //   INTEGRATION: { kind: "jira"|"github"|"linear", ... } — disabled until M19
  destConfig     Json
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  escalationLogs EscalationLog[]

  @@index([tenantId, active])
  @@map("escalation_paths")
}

model EscalationLog {
  id                String           @id @default(cuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  escalationPathId  String
  escalationPath    EscalationPath   @relation(fields: [escalationPathId], references: [id], onDelete: Cascade)
  ticketId          String
  actorTeamMemberId String?
  status            EscalationStatus
  errorMessage      String?
  createdAt         DateTime         @default(now())

  @@index([tenantId, ticketId, createdAt])
  @@map("escalation_logs")
}

// ---------------------------------------------------------------------------
// M2 — SLA & Business-Hours Engine
// ---------------------------------------------------------------------------
// SlaPolicy carries per-priority response/resolution targets as JSON:
//   { URGENT: { firstResponseMins: 60, resolutionMins: 240 }, ... }
// Storing the matrix loosely keeps the schema stable if we add new
// priorities or new target kinds later. `isDefault` marks the tenant
// fallback used when no org override matches.

model SlaPolicy {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  targets     Json // { URGENT: {firstResponseMins, resolutionMins}, ... }
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticketSlas TicketSla[]

  @@index([tenantId, active])
  @@map("sla_policies")
}

// BusinessCalendar defines the working-hours window that the dueAt
// walker respects. Weekly hours are per-day time ranges:
//   { mon: [["09:00","17:00"]], tue: [...], ..., sat: [], sun: [] }
// Holidays are ISO date strings ("YYYY-MM-DD") in the calendar's tz.
// One calendar per tenant is expected to be flagged isDefault.

model BusinessCalendar {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  timezone    String   @default("UTC") // IANA
  weeklyHours Json // per-day time ranges, see above
  holidays    Json     @default("[]")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("business_calendars")
}

enum SlaKind {
  FIRST_RESPONSE
  RESOLUTION
}

// TicketSla is the per-ticket materialization: one row per (ticket,
// kind). dueAt is calendar-adjusted at write time so read paths never
// walk business hours (see spec §3 "do NOT calculate on-read").
// pausedMs accumulates over the ticket's lifetime whenever status
// crosses into PENDING; pauseStartedAt marks an open pause. warnedAt
// / breachedAt are set by the sla.tick cron so events don't re-fire.
// satisfiedAt is computed from firstReplyAt (FIRST_RESPONSE) or
// resolvedAt (RESOLUTION) at write time when both are known.

model TicketSla {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId       String
  ticket         Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  slaPolicyId    String
  slaPolicy      SlaPolicy @relation(fields: [slaPolicyId], references: [id], onDelete: Cascade)
  kind           SlaKind
  targetMins     Int
  // @db.Timestamptz forces Postgres to store an actual instant with
  // timezone info instead of a naive `timestamp`. Prisma reads/writes
  // naive `timestamp` columns through the client's system tz — on a
  // process running in a non-UTC tz, that shifts every Date by the
  // offset, breaking the walker's dueAt math. `timestamptz` bypasses
  // that entirely.
  startedAt      DateTime  @db.Timestamptz(3)
  dueAt          DateTime  @db.Timestamptz(3)
  pausedMs       Int       @default(0)
  pauseStartedAt DateTime? @db.Timestamptz(3)
  warnedAt       DateTime? @db.Timestamptz(3)
  breachedAt     DateTime? @db.Timestamptz(3)
  satisfiedAt    DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  @@unique([ticketId, kind])
  // The sla.tick cron filters on (tenantId, dueAt window, satisfiedAt
  // null, breachedAt null) — matching index shape lets Postgres skip
  // the satisfied/breached rows quickly.
  @@index([tenantId, dueAt, satisfiedAt, breachedAt])
  @@map("ticket_slas")
}

// ===========================================================================
// M3 — Routing & Assignment Engine
// ===========================================================================
// Support-owned. teamMemberId is a scalar (no Prisma relation to the wrapper
// TeamMember, boundary rule 3). One row per team member per tenant.

model AgentProfile {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamMemberId String
  // Exact-string skill tags (e.g. "billing", "spanish"). M9 will add
  // fuzzy/synonym matching on top of this list; M3 stays exact-match.
  skills       String[] @default([])
  // Soft ceiling on open tickets. Load-based strategy skips candidates
  // whose open count >= maxOpen. 0 = unlimited (default so an admin
  // who never touches this page doesn't accidentally block routing).
  maxOpen      Int      @default(0)
  // Agent-controlled availability. Away agents are excluded from every
  // strategy. Toggled from the agent header (Available/Away chip).
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, teamMemberId])
  @@index([tenantId, isAvailable])
  @@map("agent_profiles")
}

// Loop cap for auto-reassignment. Every time routeTicket picks a new
// assignee, one row is written. The engine reads the last N rows for a
// ticket and refuses to auto-reassign if the last N are all auto-picks
// within the cap window. Manual assignments (source=MANUAL) reset the
// window.
model AutoAssignmentLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId     String
  // Picked assignee. Null on cap-halt (recorded for audit).
  teamMemberId String?
  strategy     String // "ROUND_ROBIN" | "LOAD_BASED" | "SKILLS_BASED"
  source       String // "ESCALATION" | "RULE" | "MANUAL"
  cappedOut    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([tenantId, ticketId, createdAt])
  @@map("auto_assignment_logs")
}

// M13.7 — saved analytics reports. filters mirrors the AnalyticsFilter
// shape; runNow renders a CSV export, and the (optional) schedule drives
// a periodic email sent by the send-report-schedules Inngest cron.
//
// Schedule modelling — typed frequency + hour-of-day (0..23, tenant server
// tz, matches the walker) is deliberately narrow. A raw cron string
// looked flexible but every field admins actually configure sits inside
// this enum, and computing nextRunAt from an enum is a two-line function
// vs shipping a cron parser dependency.
model SavedReport {
  id                    String               @id @default(cuid())
  tenantId              String
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  description           String?
  filters               Json                 @default("{}")
  // Recipients for a scheduled send. Empty array = on-demand only.
  recipientEmails       String[]             @default([])
  scheduleFrequency     SavedReportFrequency @default(NONE)
  // 0..23 hour-of-day the cron dispatches at. Ignored when frequency=NONE.
  scheduleHour          Int                  @default(9)
  // Absolute instant of the next scheduled dispatch. Recomputed on save
  // and on every successful send. Cron reads this to pick due rows.
  nextRunAt             DateTime?
  lastRunAt             DateTime?
  createdByTeamMemberId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([tenantId, createdAt])
  @@index([nextRunAt])
  @@map("saved_reports")
}

enum SavedReportFrequency {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

// M13 gap 3 — per-day per-tenant aggregate. Populated by the nightly
// build-ticket-rollup Inngest cron; read by the analytics trend chart
// for any day older than "today". Today still comes off the live
// tickets table so the chart reflects in-progress activity.
//
// One row per (tenantId, date). date is the day boundary in UTC (kept
// as a Date column but the cron writes it truncated to midnight so
// equality checks are exact). Filter-scoped rollups (by category, by
// priority, by org) would fan the row count by |categories|*|priorities|
// which isn't worth it — the trend chart only ever shows the plain
// daily totals; every other widget already has fast enough live paths.
model TicketDailyRollup {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  createdCount    Int      @default(0)
  resolvedCount   Int      @default(0)
  // Sum of (firstReplyAt - createdAt) in milliseconds for all tickets
  // created on this day that received a first reply — divided by
  // firstReplyCount at read time gives the daily avg first response.
  firstReplyCount Int      @default(0)
  firstReplySumMs BigInt   @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("ticket_daily_rollups")
}
