// Stralis Ticketing System — data model
// See: Stralis_Ticketing_TRD.md §3, Stralis_Build_Spec.md §B-3

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" = the dev machine; "debian-openssl-3.0.x" is for the Docker
  // image (node:*-bookworm-slim, AWS/Azure container option); "rhel-openssl-3.0.x"
  // is for Vercel's serverless functions (Amazon Linux 2023 runtime). All
  // three are generated so `prisma generate` at build time works everywhere
  // this app might run. If you switch the Docker base image to Alpine,
  // change debian-openssl-3.0.x to "linux-musl-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantType {
  INTERNAL
  CLIENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

// PENDING: self-registered, awaiting a tenant admin's approval (see the
// email flow design doc). ACTIVE: can log in. REJECTED/SUSPENDED: cannot —
// distinguished so admins can tell "we said no" from "was deactivated later".
// INVITED: an admin created this account directly (Team > Invite) — the
// person has an email link to accept but hasn't set their own password yet,
// so they can't log in normally until they do (see actions/admin.ts's
// inviteUser() and actions/auth.ts's acceptInvite()).
// UNVERIFIED: self-registered but hasn't confirmed the email is theirs yet
// (see registerClient()/verifyRegistrationOtp() in actions/auth.ts) — never
// shown in the admin approval queue, since there's no point asking an admin
// to review a registration nobody's confirmed is a real address yet.
enum UserStatus {
  UNVERIFIED
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  INVITED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SenderRole {
  CLIENT
  AGENT
  ADMIN
  SYSTEM
  BOT
  // A person added to one ticket via a guest invite link (see TicketGuest) —
  // never has a User row, so Message.senderId stays null for these and
  // Message.guestId identifies who wrote it instead.
  GUEST
}

// Z2.1 — Custom Fields (Support-owned). Values live in one polymorphic
// table keyed on (targetType, targetId); no Prisma relation to wrapper
// models (rule 3, docs/shared-platform-boundary.md §3), so USER/ORG
// targetIds are raw scalars. TICKET targetIds are Support-owned but
// still stored as raw scalars to keep one shape for all three scopes.
enum CustomFieldScope {
  USER
  ORG
  TICKET
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  DROPDOWN
  MULTISELECT
  // Z2.5 — reference another wrapper entity. Value stored as a raw scalar
  // id (`valueLookupId`) — no Prisma relation across the boundary. Sidebar
  // renders the referenced entity's name via a batch wrapper lookup.
  USER_LOOKUP
  ORG_LOOKUP
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  type         TenantType   @default(CLIENT)
  status       TenantStatus @default(ACTIVE)
  customDomain String?      @unique
  createdAt    DateTime     @default(now())

  branding             TenantBranding?
  chatbotConfig        ChatbotConfig?
  tickets              Ticket[]
  categories           Category[]
  kbArticles           KbArticle[]
  chatConversations    ChatConversation[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  ticketGuests         TicketGuest[]
  surveyResponses      SurveyResponse[]
  authCredentials      AuthCredential[]
  teamMemberLifecycles TeamMemberLifecycle[]
  endUserLifecycles    EndUserLifecycle[]
  subjectAvatars       SubjectAvatar[]
  subjectPreferences   SubjectPreference[]
  userSessions         UserSession[]
  loginActivity        LoginActivity[]
  notificationPreferences NotificationPreference[]
  digestQueue          DigestQueue[]
  dataExportRequests   DataExportRequest[]
  accountDeletionRequests AccountDeletionRequest[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  customFieldOptions     CustomFieldOption[]
  ticketForms            TicketForm[]

  @@map("tenants")
}

model TenantBranding {
  tenantId       String  @id
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#FF6A00")
  accentColor    String  @default("#000000")
  productName    String  @default("Support")
  // The tenant's one dedicated inbound support address (e.g.
  // support@acme.com) — inbound webhook matches on this to route an email
  // to the right tenant before any ticket/user exists. Unique so two
  // tenants can never claim the same inbound mailbox.
  supportEmail   String? @unique
  // Provider-side inbound route/webhook id (Resend inbound route), stored
  // for reference/cleanup — not read by the app at request time.
  inboundRouteId String?
  emailFromName  String?
  emailDomain    String?
  customCss      String?

  @@map("tenant_branding")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model Category {
  id        String               @id @default(cuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean              @default(true)
  tickets   Ticket[]
  formLinks TicketFormCategory[]

  @@unique([tenantId, name])
  @@map("categories")
}

// ---------------------------------------------------------------------------
// Tickets
// ---------------------------------------------------------------------------

model Ticket {
  id                   String       @id @default(cuid())
  tenantId             String
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference            String
  // Short numeric id (e.g. "12707664") embedded in every notification
  // subject as "[#12707664]" — kept separate from `reference` because email
  // clients mangle subject lines, so inbound reply-matching needs the
  // simplest possible token to regex out. Globally unique (not per-tenant)
  // since the inbound webhook doesn't know the tenant until it's resolved
  // the ticket this number belongs to.
  ticketNumber         String       @unique
  // Message-ID of the last outbound notification for this ticket, so a
  // client's email reply can thread back via In-Reply-To/References as a
  // fallback when the subject tag itself got stripped.
  emailMessageId       String?
  title                String
  description          String
  status               TicketStatus @default(OPEN)
  priority             Priority     @default(MEDIUM)
  categoryId           String?
  category             Category?    @relation(fields: [categoryId], references: [id])
  // Dual-FK client — CLIENT (EndUser) or staff (TeamMember, Employee
  // Service Suite pattern). Raw scalars, no Prisma relations across the
  // boundary (rule 3, docs/shared-platform-boundary.md §3). CHECK
  // tickets_client_exclusive enforces num_nonnulls <= 1.
  clientEndUserId      String?
  clientTeamMemberId   String?
  assignedTeamMemberId String?
  // Ticket.organizationId denormalizes the client's Organization for
  // analytics/routing. Populated at backfill from users.companyId; on
  // new writes populated by looking up the EndUser's primary org via
  // the wrapper's matchOrganizationByEmailDomain / EndUser.organizationId.
  organizationId       String?
  source               String       @default("portal") // portal | chatbot | email
  firstReplyAt         DateTime?
  resolvedAt           DateTime?
  // Reopen tracking (analytics: reopen-rate KPI). reopenedAt is the most
  // recent reopen timestamp; reopenCount is a running total across the
  // ticket's lifetime, incremented whenever it transitions OUT of
  // RESOLVED/CLOSED back into an active status (see reopenTicket() and
  // updateTicket() in actions/tickets.ts).
  reopenedAt           DateTime?
  reopenCount          Int          @default(0)
  // Captured at creation time from the requester's HTTP request (portal/
  // chatbot only — email-sourced tickets have no live request, so both stay
  // null). clientCountry is an ISO 3166-1 alpha-2 code resolved from
  // clientIp via geoip-lite (offline lookup, no external API call) —
  // powers the analytics "clients by region" map/table. Never backfilled
  // for tickets created before this field existed.
  clientIp             String?
  clientCountry        String?
  // Z2.3: the ticket form the client picked (if any). Nullable — legacy
  // tickets and email-sourced ones have no form.
  ticketFormId         String?
  ticketForm           TicketForm?  @relation(fields: [ticketFormId], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  messages          Message[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  chatConversations ChatConversation[]
  notifications     Notification[]
  guests            TicketGuest[]
  surveyResponse    SurveyResponse?

  @@unique([tenantId, reference])
  @@index([tenantId, status, priority])
  @@index([tenantId, clientEndUserId])
  @@index([tenantId, clientTeamMemberId])
  @@index([tenantId, assignedTeamMemberId])
  @@index([tenantId, organizationId])
  @@map("tickets")
}

// One CSAT rating per ticket — see actions/csat.ts's submitCsatRating()
// (an unauthenticated, token-scoped action reached via the emailed
// "rate this ticket" link, actions/tickets.ts's updateTicket()). Resubmitting
// the same link overwrites the existing row rather than erroring, so
// ticketId is unique instead of having its own separate id-based history.
model SurveyResponse {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("survey_responses")
}

model Message {
  id                 String       @id @default(cuid())
  tenantId           String
  ticketId           String
  ticket             Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Guest author: no wrapper counterpart (no account) — a guest never has an
  // EndUser row, so this identifies who wrote the message.
  guestId            String?
  guest              TicketGuest? @relation(fields: [guestId], references: [id])
  // Dual-FK author (wrapper): EndUser (client) or TeamMember (staff). Raw
  // scalars, no Prisma relations across the boundary (rule 3). CHECK
  // messages_sender_exclusive: num_nonnulls(senderEndUserId,
  // senderTeamMemberId, guestId) <= 1 — SYSTEM/BOT rows are all-null.
  senderEndUserId    String?
  senderTeamMemberId String?
  senderRole         SenderRole
  body               String
  isInternal         Boolean      @default(false)
  createdAt          DateTime     @default(now())

  attachments Attachment[]

  @@index([tenantId, ticketId])
  @@index([tenantId, senderEndUserId])
  @@index([tenantId, senderTeamMemberId])
  @@map("messages")
}

model Attachment {
  id                     String   @id @default(cuid())
  tenantId               String
  ticketId               String
  ticket                 Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Null until the composer's "Send" actually posts the message the file was
  // staged for (see actions/attachments.ts uploadTicketAttachment /
  // actions/tickets.ts's postAgentReply|postClientReply) — an uploaded-but-
  // never-sent file just stays unlinked, still visible in Files & Links.
  messageId              String?
  message                Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // Dual-FK uploader (wrapper). Raw scalars — no Prisma relations across
  // the boundary (rule 3).
  uploadedByEndUserId    String?
  uploadedByTeamMemberId String?
  // Storage object PATH, not a public URL — this bucket is private (ticket
  // attachments aren't "public by nature" like branding logos/avatars are).
  // Resolved to a short-lived signed URL on read; see lib/storage.ts.
  fileUrl                String
  fileName               String
  mimeType               String
  sizeBytes              Int
  uploadedAt             DateTime @default(now())

  @@index([tenantId, ticketId])
  @@index([messageId])
  @@index([tenantId, uploadedByEndUserId])
  @@index([tenantId, uploadedByTeamMemberId])
  @@map("attachments")
}

// A person added to exactly one ticket via an emailed magic link — no
// account, no password, no session cookie. invitedById is the staff/client
// User who added them; the guest's own identity is just email (+ optional
// name) carried on this row and denormalized onto any Message they send
// (Message.guestId). tokenHash is sha256 of the raw token that goes in the
// email; only the hash is ever stored (same pattern as password-reset,
// except this one needs server-side state since it's revocable/long-lived
// rather than a short single-use JWT).
model TicketGuest {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId              String
  ticket                Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  email                 String
  name                  String?
  tokenHash             String    @unique
  // Dual-FK inviter (wrapper). Raw scalars.
  invitedByEndUserId    String?
  invitedByTeamMemberId String?
  createdAt             DateTime  @default(now())
  revokedAt             DateTime?

  messages Message[]

  @@index([tenantId, ticketId])
  @@index([tenantId, invitedByEndUserId])
  @@index([tenantId, invitedByTeamMemberId])
  @@map("ticket_guests")
}

// Server-side state for the one-time email code verified at invite
// acceptance (first login only — see actions/auth.ts's acceptInvite() /
// verifyLoginOtp()). Deliberately NOT a JWT like session/reset tokens,
// since a code needs to be matched against a value already emailed out
// (can't just re-derive/re-verify a signature the way a stateless token
// works) and single-use tracked independent of any password change.
model LoginOtp {
  id           String    @id @default(cuid())
  tenantId     String
  // Dual-FK subject (wrapper). Exactly one must be non-null (CHECK
  // login_otps_subject_present enforces at DB level). Raw scalars.
  endUserId    String?
  teamMemberId String?
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([endUserId])
  @@index([teamMemberId])
  @@map("login_otps")
}

model AuditLog {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId          String?
  ticket            Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Dual-FK actor (wrapper). Raw scalars. CHECK audit_logs_actor_exclusive:
  // num_nonnulls(actorEndUserId, actorTeamMemberId) <= 1 — SYSTEM rows all-null.
  actorEndUserId    String?
  actorTeamMemberId String?
  action            String // STATUS_CHANGE | PRIORITY_CHANGE | ASSIGN | REPLY | REOPEN | ...
  fromValue         String?
  toValue           String?
  createdAt         DateTime @default(now())

  @@index([tenantId, ticketId])
  @@index([tenantId, actorEndUserId])
  @@index([tenantId, actorTeamMemberId])
  @@map("audit_logs")
}

// In-app notification bell (nav-bar.tsx). Deliberately separate from the
// email system (lib/email/) — a notification is a personal, per-user inbox
// item ("you were assigned a ticket"), not a tenant-wide log like AuditLog
// or an outbound message like the email templates. Written via createMany()
// everywhere (see lib/notifications.ts), never .create() — Prisma's
// .create() always does an implicit RETURNING checked against SELECT
// policies, and the actor creating a notification (e.g. a client replying)
// is essentially never the same user as the notification's recipient (the
// assigned agent), so that RETURNING check would fail under RLS the same
// way the audit_logs one originally did (see rls_policies.sql). createMany()
// has no RETURNING, sidestepping the problem entirely — we don't need the
// created row back anyway.
model Notification {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Dual-FK recipient (wrapper). Exactly one must be non-null (CHECK
  // notifications_recipient_present).
  recipientEndUserId    String?
  recipientTeamMemberId String?
  type                  String // TICKET_REPLY | STATUS_CHANGE | ASSIGNED | REGISTRATION_PENDING | REGISTRATION_APPROVED | REGISTRATION_REJECTED
  title                 String
  body                  String?
  ticketId              String?
  ticket                Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  isRead                Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([tenantId, recipientEndUserId, isRead, createdAt])
  @@index([tenantId, recipientTeamMemberId, isRead, createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Auth + lifecycle (Z1.8 Set B — see docs/adrs/adr-001-z1-8-auth-model-set-b.md)
// ---------------------------------------------------------------------------
//
// Support-owned tables introduced in Z1.8 to move password + lifecycle state
// off the legacy `users` table ahead of Z1.5's drop. Set B (per ADR-001):
// Support owns its auth surface; wrapper stays identity-only.
//
// Design notes:
//   - subjectEndUserId / subjectTeamMemberId / subjectId are raw scalar
//     columns (not Prisma relations), matching the Z1.4a dual-FK precedent —
//     enforcement is via CHECK constraint on auth_credentials and via
//     single-column PK on the lifecycle tables. See
//     docs/shared-platform-boundary.md §3 rule 3. Cascade ownership stays
//     on the wrapper's team.
//   - status uses the existing UserStatus enum, preserving Team & Roles v2
//     PR #21's 6-state model as ADR-001 committed to.
//   - AuthCredential.id is a fresh cuid at row-creation time; matches to
//     legacy `users.id` go via subjectEndUserId or subjectTeamMemberId
//     (which ARE preserved from Z1.3), never by direct id comparison. See
//     prisma/z1_8a_migration.sql header for the drift-check convention.
//   - Dual-write with legacy `users` runs from Z1.8a through Z1.5. Legacy
//     stays read-authoritative until Z1.5 removes it.

model AuthCredential {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectEndUserId    String?
  subjectTeamMemberId String?
  passwordHash        String
  passwordChangedAt   DateTime?
  // M21.2 — email-change flow. `pendingEmail` is the address the confirmation
  // link resolves to; cleared on confirm (or by a fresh request superseding it).
  // Held Support-side because the wrapper email column stays authoritative
  // for identity; nothing outside this flow reads pendingEmail.
  pendingEmail            String?
  pendingEmailRequestedAt DateTime?
  mfaSecret           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId, subjectEndUserId])
  @@index([tenantId, subjectTeamMemberId])
  @@map("auth_credentials")
}

model TeamMemberLifecycle {
  subjectId    String     @id
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       UserStatus
  invitedAt    DateTime?
  invitedById  String?
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?
  lastActiveAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, status])
  @@map("team_member_lifecycle")
}

// Z1.7 — Support-owned avatar store. Same Set B rationale as
// AuthCredential + *Lifecycle: wrapper stays identity-only, Support
// owns UI concerns. Keyed by subjectId (unique across end_users /
// team_members thanks to Z1.3 preserved-ids). Written by
// actions/profile.ts's uploadProfilePicture; read by getSessionUser
// and by list views via lib/avatars.ts's getAvatarUrlsByIds().
model SubjectAvatar {
  subjectId String   @id
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("subject_avatars")
}

// M21.1 — Support-owned user preferences (timezone, language). Same Set
// B pattern as SubjectAvatar: wrapper stays identity-only, Support owns
// UI concerns. Keyed by subjectId (unique across end_users / team_members
// thanks to Z1.3 preserved-ids). Density / theme / defaultLanding are
// reserved for M21.5 (Appearance tab) but the columns land here so a
// second migration isn't needed.
model SubjectPreference {
  subjectId      String   @id
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timezone       String?
  language       String?
  theme          String?
  density        String?
  defaultLanding String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@map("subject_preferences")
}

// M21.3 — per-device session tracking. Every issued session cookie
// carries a `sessionId` claim; getSessionUser rejects any cookie whose
// row is missing or expired. Revoking a session = deleting its row.
// `subjectKind` mirrors the SessionPayload TS union — kept as a plain
// string column (not a Prisma enum) so this table works with either
// end_users or team_members without a wrapper-owned enum.
model UserSession {
  id           String   @id
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId    String
  subjectKind  String
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  @@index([tenantId, subjectId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// M21.3 — append-only login history. Populated in actions/auth.ts's
// login() on every successful sign-in. Displayed in the Security tab.
// Kept separate from UserSession so revoking a session doesn't erase the
// audit trail.
model LoginActivity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId   String
  subjectKind String
  userAgent   String?
  ipAddress   String?
  country     String?
  createdAt   DateTime @default(now())

  @@index([tenantId, subjectId, createdAt])
  @@map("login_activity")
}

// M21.4 — per-subject notification preferences. Each column gates one
// specific event; the `digestMode` column swaps real-time email delivery
// for a queued daily summary drained by an Inngest job. Every column
// defaults to `true` so a user who has never touched the tab keeps
// getting the same emails they got pre-M21.4.
model NotificationPreference {
  subjectId          String   @id
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailTicketCreated Boolean  @default(true)
  emailTicketReply   Boolean  @default(true)
  emailStatusChange  Boolean  @default(true)
  emailAssigned      Boolean  @default(true)
  emailCsatRequest   Boolean  @default(true)
  inAppTicketReply   Boolean  @default(true)
  inAppStatusChange  Boolean  @default(true)
  inAppAssigned      Boolean  @default(true)
  digestMode         String   @default("INSTANT")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@map("notification_preferences")
}

// M21.4 — queued email events for subjects whose digestMode is DAILY.
// Drained by the daily-digest Inngest job (src/lib/inngest/functions/
// send-daily-digests.ts); rows are deleted once bundled into an email.
model DigestQueue {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId String
  eventKey  String
  subject   String
  body      String
  ticketRef String?
  ticketUrl String?
  createdAt DateTime @default(now())

  @@index([tenantId, subjectId, createdAt])
  @@map("digest_queue")
}

// M21.6 — data export requests. Kicked off from the Danger Zone; the
// build-data-export Inngest job collects the subject's records into
// `payload` (Jsonb), then a signed token gives the download route
// (`/api/data-export/[token]`) permission to serve them. `expiresAt`
// is enforced at read time — the row lingers past that for
// audit/history but the download won't work.
model DataExportRequest {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId String
  status    String   @default("PENDING")
  payload   Json?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, subjectId])
  @@map("data_export_requests")
}

// M21.6 — account deletion requests. The user submits (last-Super-Admin
// guard applied at submit time so a doomed request never lands in the
// queue). Rows in PENDING appear on the admin's approval page; on
// APPROVED the user is actually deleted, on REJECTED they stay active.
model AccountDeletionRequest {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId    String
  reason       String?
  status       String    @default("PENDING")
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, status, createdAt])
  @@map("account_deletion_requests")
}

model EndUserLifecycle {
  subjectId    String     @id
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       UserStatus
  invitedAt    DateTime?
  invitedById  String?
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?
  lastActiveAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, status])
  @@map("end_user_lifecycle")
}

// ---------------------------------------------------------------------------
// Z2.1 — Custom Fields
//
// One definition table + one polymorphic value table. `key` is immutable
// (label/isRequired/position can change); placeholder resolvers
// (`{{ticket.custom_fields.<key>}}`) and integrations depend on the key
// staying stable. Uniqueness is (tenantId, scope, key) so USER and TICKET
// can both have a "priority" key without collision.
//
// Deactivation, not deletion: definitions carry `isActive` — values are
// kept so historical tickets keep their sidebar data. See Z2 spec §3.
// ---------------------------------------------------------------------------

model CustomFieldDefinition {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scope       CustomFieldScope
  type        CustomFieldType
  // Immutable after create — see §3 of the Z2 spec. Lowercase snake_case,
  // cannot start with a digit; enforced at the action layer (Zod) and
  // the unique index below.
  key         String
  label       String
  description String?
  isActive    Boolean          @default(true)
  isRequired  Boolean          @default(false)
  // Display order within a (scope) column on admin/detail sidebars.
  position    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  values     CustomFieldValue[]
  options    CustomFieldOption[]
  formFields TicketFormField[]

  @@unique([tenantId, scope, key])
  @@index([tenantId, scope, isActive])
  @@map("custom_field_definitions")
}

// Z2.2 — Options for DROPDOWN / MULTISELECT fields.
//
// `value` is the stable identifier (like the key on a definition — used by
// placeholder resolvers, trigger conditions, and integrations). `label` is
// the display text and is freely renamable. Uniqueness is per definition
// so two fields can each have an option called "high" without collision.
//
// `implicitTag` is Zendesk-style: selecting this option can apply a tag to
// the entity. Stored as free text (not a Tag FK) because (a) the mapping
// should survive tag renames, and (b) TICKET-scoped fields want this too
// but ticket tagging isn't yet a first-class concept — trigger/rule
// engines (Z8) will consume this string and do the tag write.
model CustomFieldOption {
  id                String                @id @default(cuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  value             String
  label             String
  position          Int                   @default(0)
  implicitTag       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([fieldDefinitionId, value])
  @@index([tenantId])
  @@index([fieldDefinitionId, position])
  @@map("custom_field_options")
}

// ---------------------------------------------------------------------------
// Z2.3 — Ticket Forms
//
// A form is a curated ordered subset of TICKET-scoped CustomFieldDefinitions
// pinned to zero or more Categories. When a client picks a category on the
// portal, the first (position-ordered, active) TicketForm whose
// `categories` list contains that category is used to render extra fields.
// If no form pins a category, no custom fields are shown.
//
// Only TICKET-scoped definitions can be added to a form (enforced in the
// action layer). USER/ORG fields live only on the entity's own sidebar.
// ---------------------------------------------------------------------------

model TicketForm {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields     TicketFormField[]
  categories TicketFormCategory[]
  tickets    Ticket[]

  @@index([tenantId, isActive])
  @@map("ticket_forms")
}

model TicketFormField {
  id                 String                @id @default(cuid())
  tenantId           String
  ticketFormId       String
  ticketForm         TicketForm            @relation(fields: [ticketFormId], references: [id], onDelete: Cascade)
  fieldDefinitionId  String
  fieldDefinition    CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  position           Int                   @default(0)
  // Overrides CustomFieldDefinition.isRequired for this form only. Lets a
  // form say "on THIS intake path we don't need service_tier" even if the
  // sidebar edit view still marks it required.
  isRequiredOverride Boolean?
  // Z2.4 — conditional visibility. When set, this field only shows on the
  // form if the sibling field's value equals `visibleWhenValue` (string
  // equality — Z2 spec §3 limits us to single-condition rules).
  visibleWhenFieldId String?
  visibleWhenValue   String?

  @@unique([ticketFormId, fieldDefinitionId])
  @@index([tenantId])
  @@index([ticketFormId, position])
  @@map("ticket_form_fields")
}

model TicketFormCategory {
  ticketFormId String
  ticketForm   TicketForm @relation(fields: [ticketFormId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantId     String

  @@id([ticketFormId, categoryId])
  @@index([tenantId, categoryId])
  @@map("ticket_form_categories")
}

model CustomFieldValue {
  id                String                @id @default(cuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  // Polymorphic target — mirrors the definition's scope. targetId is a
  // raw scalar for USER (end_users.id) / ORG (organizations.id) because
  // those are wrapper-owned; TICKET (tickets.id) is Support-owned but
  // stored the same way so all three scopes share one query shape.
  targetType        CustomFieldScope
  targetId          String
  // Typed value columns. Exactly one is populated per row, matching the
  // definition's `type`. A CHECK constraint in the migration enforces
  // this at the DB level; the actions layer enforces it in Zod first.
  valueText         String?
  valueNumber       Decimal?              @db.Decimal(20, 6)
  valueDate         DateTime?
  valueBoolean      Boolean?
  // Z2.2: single-option pick for DROPDOWN.
  valueOptionId     String?
  // Z2.2: multi-option pick for MULTISELECT. Default `[]` so the CHECK
  // constraint's "empty array == not set" convention works out of the box
  // for TEXT/NUMBER/etc. rows. Postgres text[]; queryable via `@>`.
  valueOptionIds    String[]              @default([])
  // Z2.5: id of the referenced wrapper entity (EndUser for USER_LOOKUP,
  // Organization for ORG_LOOKUP). Raw scalar — no Prisma relation.
  valueLookupId     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([fieldDefinitionId, targetId])
  @@index([tenantId, targetType, targetId])
  @@map("custom_field_values")
}

// ---------------------------------------------------------------------------
// AI / Knowledge base / Chatbot
// ---------------------------------------------------------------------------

model KbArticle {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  body        String
  isPublished Boolean   @default(false)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  chunks      KbChunk[]

  @@index([tenantId])
  @@map("kb_articles")
}

model KbChunk {
  id        String    @id @default(cuid())
  tenantId  String
  articleId String
  article   KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  // TODO(decision): swap to pgvector `vector(1536)` once the AI/M5 milestone
  // is built and a Postgres with the pgvector extension is provisioned.
  // Storing as a plain float array keeps local dev unblocked without it.
  embedding Json?

  @@index([tenantId])
  @@map("kb_chunks")
}

model ChatbotConfig {
  tenantId      String  @id
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled     Boolean @default(true)
  persona       String  @default("a friendly support assistant")
  systemPrompt  String?
  deflectFirst  Boolean @default(true)
  escalateAfter Int     @default(3)
  allowedTopics String?

  @@map("chatbot_configs")
}

model ChatConversation {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Dual-FK subject (wrapper). Raw scalars.
  endUserId    String?
  teamMemberId String?
  status       String        @default("active") // active | escalated | closed
  ticketId     String?
  ticket       Ticket?       @relation(fields: [ticketId], references: [id])
  createdAt    DateTime      @default(now())
  messages     ChatMessage[]

  @@index([tenantId])
  @@index([tenantId, endUserId])
  @@index([tenantId, teamMemberId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           SenderRole
  body           String
  citations      Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ===========================================================================
// STRALIS SHARED PLATFORM — REFERENCE MODELS (Z1: Six-Object Model Refactor)
// ===========================================================================
//
// These 9 tables + 3 enums are OWNED BY THE STRALIS SHARED PLATFORM REPO
// (../Stralis Shared Platform/prisma/schema.prisma). Both repos connect to
// the same physical Postgres database (see the Shared Platform's ADR-004,
// "Single Public Schema Ownership by Convention"). Ownership is enforced by
// docs + code review, not the database — every table below lives in
// Postgres's public schema, same as this repo's own tables.
//
// WHY THEY'RE MIRRORED HERE:
//   - So this repo's `prisma generate` produces TypeScript types + a working
//     Prisma Client for these models, letting server actions query and
//     mutate them the same way any local model works.
//   - This is the pre-M7 arrangement: this repo talks to the shared tables
//     via Prisma directly through the wrapper service in
//     src/lib/shared-platform/. Once the Shared Platform's Public API (M7)
//     ships, the wrapper flips from Prisma to HTTP fetch and the models
//     below can be removed. See docs/shared-platform-boundary.md.
//
// RULES:
//   1. NEVER edit a model or enum in this block. If the Shared Platform
//      ships schema changes to core, run `npm run pull-core` (which for now
//      is a manual copy-paste from the Shared Platform's schema.prisma) and
//      commit the diff — do not hand-edit.
//   2. NEVER run `prisma migrate dev` or `prisma db push` in this repo
//      while these models are present unless every model matches the DB's
//      current state exactly. If they match, `db push` is a no-op and
//      that's fine; if they don't, `db push` will corrupt the shared DB.
//   3. NEVER introduce a Prisma relation FROM a Support-owned model TO one
//      of the shared models (e.g. don't add `endUser EndUser @relation(...)`
//      on Ticket). FKs cross the boundary; Prisma relations don't. Use raw
//      scalar `endUserId String?` columns and resolve via the wrapper.
//   4. Tenant is NOT mirrored here because it stays owned by THIS repo.
//      The shared platform stores tenantId as a plain scalar and enforces
//      the FK at the SQL level (see their migration.sql). Migrating Tenant
//      to the shared platform is a deliberate future ADR — not decided as
//      a side effect of Z1. See docs/shared-platform-boundary.md.
//
// If any of these rules would need to be broken to ship a feature, STOP and
// escalate — either the boundary is wrong (unlikely) or the feature is
// designed against it (fixable).

enum TicketAccessScope {
  ALL
  GROUPS
  ASSIGNED_ONLY
}

enum TagTargetType {
  END_USER
  TEAM_MEMBER
  ORGANIZATION
}

enum AuditActorType {
  TEAM_MEMBER
  SYSTEM
}

model Organization {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  endUsers           EndUser[]
  endUserMemberships EndUserOrganization[]

  @@unique([tenantId, name])
  @@index([tenantId, domain])
  @@map("organizations")
}

model EndUser {
  id             String        @id @default(cuid())
  tenantId       String
  email          String
  name           String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organizationMemberships EndUserOrganization[]

  @@unique([tenantId, email])
  @@index([tenantId, organizationId])
  @@map("end_users")
}

model EndUserOrganization {
  endUserId      String
  endUser        EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId       String
  createdAt      DateTime     @default(now())

  @@id([endUserId, organizationId])
  @@index([tenantId])
  @@map("end_user_organizations")
}

model TeamMember {
  id                String            @id @default(cuid())
  tenantId          String
  email             String
  name              String?
  roleId            String
  role              Role              @relation(fields: [roleId], references: [id])
  ticketAccessScope TicketAccessScope @default(ASSIGNED_ONLY)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  groupMemberships TeamMemberGroup[]

  @@unique([tenantId, email])
  @@index([tenantId, roleId])
  @@map("team_members")
}

model Group {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships TeamMemberGroup[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("groups")
}

model TeamMemberGroup {
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  groupId      String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tenantId     String
  createdAt    DateTime   @default(now())

  @@id([teamMemberId, groupId])
  @@index([tenantId])
  @@map("team_member_groups")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  isCustom    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamMembers TeamMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#7A7A7A")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments TagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model TagAssignment {
  id         String        @id @default(cuid())
  tenantId   String
  tagId      String
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  targetType TagTargetType
  targetId   String
  createdAt  DateTime      @default(now())

  @@unique([tenantId, tagId, targetType, targetId])
  @@index([tenantId, targetType, targetId])
  @@map("tag_assignments")
}

model CoreAuditLog {
  id           String         @id @default(cuid())
  tenantId     String
  actorId      String?
  actorType    AuditActorType
  action       String // CREATE | UPDATE | DELETE | ASSIGN | ...
  resourceType String // "Organization" | "EndUser" | "TeamMember" | "Group" | "Role" | "Tag" | ...
  resourceId   String
  fromValue    Json?
  toValue      Json?
  createdAt    DateTime       @default(now())

  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, createdAt])
  @@map("core_audit_logs")
}

