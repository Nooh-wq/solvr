{
  "name": "stralis-ticketing-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local-db": "concurrently -n pg,next -c yellow,cyan \"npm:db:local\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:local": "node scripts/local-pg-server.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:rls": "node scripts/apply-rls.mjs",
    "db:studio": "prisma studio",
    "db:setup": "npm run db:push && npm run db:rls && npm run db:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@aws-sdk/client-sesv2": "^3.1079.0",
    "@electric-sql/pglite": "^0.5.3",
    "@electric-sql/pglite-socket": "^0.2.6",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
    "inngest": "^4.11.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^6.6.5",
    "resend": "^6.16.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
